#!/bin/bash
set -euo pipefail
[[ -n "${BX_INSIDE:-}" ]] && { echo "bx: already inside a bx sandbox" >&2; exit 1; }
export BX_INSIDE=1

# bx — project-aware bwrap sandbox manager

PROJECT_DIR="$(pwd)"
CONFIG_DIR="$PROJECT_DIR/.bx"
CONFIG_FILE="$CONFIG_DIR/config"
MOUNTS_FILE="$CONFIG_DIR/mounts"
HOME_DIR="$CONFIG_DIR/home"
SANDBOX_HOME="$(getent passwd "$(id -u)" | cut -d: -f6)"
SANDBOX_HOME="${SANDBOX_HOME:-$HOME}"
HOST_USER="$(id -un)"
PROVISION_SCRIPT="$CONFIG_DIR/provision.sh"
PROVISION_STAMP="$CONFIG_DIR/.provisioned"
BASHRC_FILE="$HOME_DIR/.bashrc"
BASHRC_VERSION=2
BASHRC_VERSION_STAMP="# bx-bashrc-version: $BASHRC_VERSION"

BX_UNSETENV_VARS=(
    LD_LIBRARY_PATH
    LD_PRELOAD
    HOMEBREW_CELLAR
    HOMEBREW_PREFIX
    HOMEBREW_REPOSITORY
    INFOPATH
    PYTHONPATH
    PERL5LIB
    RUBYLIB
    NODE_PATH
    __MISE_DIFF
    __MISE_SESSION
    __MISE_ORIG_PATH
    DIRENV_DIFF
    DIRENV_DIR
    DIRENV_FILE
    DIRENV_WATCHES
    ATUIN_HISTORY_ID
    ATUIN_HOST_NAME
    ATUIN_HOST_USER
    ATUIN_LOG
    ATUIN_SESSION
    BLE_SESSION_ID
    bleopt_connect_tty
    STARSHIP_SESSION_KEY
    STARSHIP_SHELL
    SESSION_MANAGER
    DESKTOP_SESSION
    GDMSESSION
    WINDOWID
    MATE_DESKTOP_SESSION_ID
)

trim() {
    local s="$1"
    s="${s#"${s%%[![:space:]]*}"}"
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "${s%$'\r'}"
}

expand_path() {
    local p="$1"
    case "$p" in
        "~") printf '%s' "$HOME" ;;
        ~/*) printf '%s' "$HOME/${p#~/}" ;;
        *) printf '%s' "$p" ;;
    esac
}

resolve_workdir() {
    local configured="${WORKDIR:-$PROJECT_DIR}"
    local legacy="/workspace/$(basename "$PROJECT_DIR")"
    if [[ "$configured" == "$legacy" ]]; then
        printf '%s' "$PROJECT_DIR"
    else
        printf '%s' "$configured"
    fi
}

load_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo "No .bx/config found. Run 'bx init' first." >&2
        exit 1
    fi
    source "$CONFIG_FILE"
}

run_provision_if_needed() {
    [[ -f "$PROVISION_SCRIPT" ]] || return 0
    [[ -f "$PROVISION_STAMP" ]] && return 0

    echo "==> Running .bx/provision.sh (one-time)..."
    (
        cd "$PROJECT_DIR"
        PROJECT_DIR="$PROJECT_DIR" CONFIG_DIR="$CONFIG_DIR" HOME_DIR="$HOME_DIR" bash "$PROVISION_SCRIPT"
    )
    date -Is > "$PROVISION_STAMP"
}

write_bashrc_template() {
    cat > "$BASHRC_FILE" <<'BASHRC'
# bx-bashrc-version: 2
if command -v mise &>/dev/null; then
    eval "$(mise activate bash)"
fi

if [[ -f ~/.bash_aliases ]]; then
    . ~/.bash_aliases
fi

export PS1='\[\e[1;33m\]\u@bwrap:\[\e[0m\]\[\e[1;34m\]\w\[\e[0m\]\$ '
export TERM="${TERM:-xterm-256color}"
export EDITOR="${EDITOR:-nvim}"

if [[ -n "${BX_PROJECT_BIN:-}" ]]; then
    PATH=":$PATH:"
    PATH="${PATH//:$BX_PROJECT_BIN:/:}"
    PATH="${PATH#:}"; PATH="${PATH%:}"
    export PATH="$BX_PROJECT_BIN:$PATH"
fi
BASHRC
}

migrate_bashrc_if_needed() {
    local current_stamp=""

    mkdir -p "$HOME_DIR"
    if [[ -f "$BASHRC_FILE" ]]; then
        IFS= read -r current_stamp < "$BASHRC_FILE" || true
    fi

    if [[ "$current_stamp" != "$BASHRC_VERSION_STAMP" ]]; then
        write_bashrc_template
        echo "==> migrated .bx/home/.bashrc to v2" >&2
    fi
}

emit_unsetenv_args() {
    local -n _args_ref="$1"
    local var

    for var in "${BX_UNSETENV_VARS[@]}"; do
        _args_ref+=(--unsetenv "$var")
    done

    # BLE leaks many internal _ble_util_* vars; enumerate dynamically because bwrap only unsets literal names.
    while IFS= read -r var; do
        [[ -n "$var" ]] || continue
        _args_ref+=(--unsetenv "$var")
    done < <(compgen -e | grep '^_ble_util_' || true)
}

parse_mount_line() {
    local raw="$1"
    local cleaned
    cleaned="$(trim "$raw")"

    [[ -z "$cleaned" || "$cleaned" == \#* ]] && return 1

    local src="" dst="" mode="ro" extra=""

    # Legacy format compatibility: src:dst[:ro|rw]
    if [[ "$cleaned" == *:* && "$cleaned" != *" "* && "$cleaned" != *$'\t'* ]]; then
        IFS=':' read -r src dst mode extra <<< "$cleaned"
        [[ -z "$src" || -z "$dst" || -n "${extra:-}" ]] && return 1
        [[ -n "${mode:-}" && "$mode" != "ro" && "$mode" != "rw" ]] && return 1
        mode="${mode:-ro}"
    else
        local parts=()
        read -r -a parts <<< "$cleaned"
        case "${#parts[@]}" in
            1)
                src="${parts[0]}"
                dst="$src"
                mode="ro"
                ;;
            2)
                src="${parts[0]}"
                if [[ "${parts[1]}" == "ro" || "${parts[1]}" == "rw" ]]; then
                    dst="$src"
                    mode="${parts[1]}"
                else
                    dst="${parts[1]}"
                    mode="ro"
                fi
                ;;
            3)
                src="${parts[0]}"
                dst="${parts[1]}"
                mode="${parts[2]}"
                [[ "$mode" != "ro" && "$mode" != "rw" ]] && return 1
                ;;
            *)
                return 1
                ;;
        esac
    fi

    src="$(expand_path "$src")"
    dst="$(expand_path "$dst")"

    [[ "$src" == /* && "$dst" == /* ]] || return 1

    printf '%s\t%s\t%s\n' "$src" "$dst" "$mode"
}

# destination -> source/mode (later files override earlier files)
declare -A MOUNT_SRC=()
declare -A MOUNT_MODE=()

collect_mounts_from_file() {
    local file="$1"
    [[ -f "$file" ]] || return 0

    local line parsed src dst mode
    while IFS= read -r line || [[ -n "$line" ]]; do
        if ! parsed="$(parse_mount_line "$line")"; then
            continue
        fi
        IFS=$'\t' read -r src dst mode <<< "$parsed"

        [[ -e "$src" ]] || continue

        MOUNT_SRC["$dst"]="$src"
        MOUNT_MODE["$dst"]="$mode"
    done < "$file"
}

ensure_home_mountpoint() {
    local src="$1"
    local dst="$2"

    [[ "$dst" == "$SANDBOX_HOME" || "$dst" == "$SANDBOX_HOME"/* ]] || return 0

    local rel="${dst#$SANDBOX_HOME}"
    local target="$HOME_DIR$rel"
    local parent
    parent="$(dirname "$target")"
    mkdir -p "$parent"

    if [[ -d "$src" ]]; then
        mkdir -p "$target"
    elif [[ ! -e "$target" ]]; then
        : > "$target"
    fi
}

emit_custom_mount_args() {
    local -n _args_ref="$1"
    local dst src mode

    for dst in "${!MOUNT_SRC[@]}"; do
        src="${MOUNT_SRC[$dst]}"
        mode="${MOUNT_MODE[$dst]}"

        ensure_home_mountpoint "$src" "$dst"

        if [[ "$mode" == "rw" ]]; then
            _args_ref+=(--bind "$src" "$dst")
        else
            _args_ref+=(--ro-bind "$src" "$dst")
        fi
    done
}

emit_standard_ro_mount() {
    local -n _args_ref="$1"
    local dst="$2"
    local src

    [[ -e "$dst" ]] || return 0
    src="$(readlink -f "$dst")"
    [[ -n "$src" ]] || return 0

    if [[ -L "$dst" ]]; then
        _args_ref+=(--dir "$(dirname "$src")" --ro-bind "$src" "$src")
    else
        _args_ref+=(--ro-bind "$src" "$dst")
    fi
}

ensure_mounts_file_seeded() {
    mkdir -p "$CONFIG_DIR"
    [[ -e "$MOUNTS_FILE" ]] || touch "$MOUNTS_FILE"
}

cmd_init() {
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
        echo "Already initialized for '$(basename "$PROJECT_DIR")'."
        exit 0
    fi

    local workdir="$PROJECT_DIR"

    # Pre-create home structure — mount points for bind mounts
    mkdir -p \
        "$HOME_DIR/.local" \
        "$HOME_DIR/.claude" \
        "$HOME_DIR/.config/mise" \
        "$HOME_DIR/.ssh"

    # Minimal claude settings (avoids theme picker on first run)
    echo '{"theme":"dark","model":"sonnet","skipDangerousModePermissionPrompt":true}' > "$HOME_DIR/.claude/settings.json"

    cat > "$CONFIG_FILE" <<EOF
WORKDIR=$workdir
GUI=off
SSH=off
DBUS=off
CLAUDE=on
CODEX=on
EOF

    ensure_mounts_file_seeded

    write_bashrc_template

    cat > "$HOME_DIR/.bash_profile" <<'BASH_PROFILE'
[[ -f ~/.bashrc ]] && . ~/.bashrc
BASH_PROFILE

    run_provision_if_needed

    echo "==> Initialized bx sandbox for '$(basename "$PROJECT_DIR")'"
    echo "    Workdir: $workdir"
    echo "    Home:    $HOME_DIR"
    echo ""
    echo "    bx enter    — shell in"
    echo "    bx run CMD  — run a command"
}

run_bwrap() {
    load_config
    migrate_bashrc_if_needed

    # Sync auth files from host on every entry (tokens refresh daily, inode changes)
    if [[ "${CLAUDE:-on}" == "on" ]]; then
        mkdir -p "$HOME_DIR/.claude"
        if [[ -f "$HOME/.claude.json" ]] && [[ ! "$HOME/.claude.json" -ef "$HOME_DIR/.claude.json" ]]; then
            cp "$HOME/.claude.json" "$HOME_DIR/.claude.json"
        fi
        if [[ -f "$HOME/.claude/.credentials.json" ]] && [[ ! "$HOME/.claude/.credentials.json" -ef "$HOME_DIR/.claude/.credentials.json" ]]; then
            cp "$HOME/.claude/.credentials.json" "$HOME_DIR/.claude/.credentials.json"
        fi
    fi

    # Sync codex auth + config on every entry (auth.json replaced atomically on refresh)
    if [[ "${CODEX:-on}" == "on" ]] && [[ -d "$HOME/.codex" ]]; then
        mkdir -p "$HOME_DIR/.codex"
        if [[ -f "$HOME/.codex/auth.json" ]] && [[ ! "$HOME/.codex/auth.json" -ef "$HOME_DIR/.codex/auth.json" ]]; then
            cp "$HOME/.codex/auth.json" "$HOME_DIR/.codex/auth.json"
        fi
        if [[ -f "$HOME/.codex/config.toml" ]] && [[ ! "$HOME/.codex/config.toml" -ef "$HOME_DIR/.codex/config.toml" ]]; then
            cp "$HOME/.codex/config.toml" "$HOME_DIR/.codex/config.toml"
        fi
    fi

    local workdir
    workdir="$(resolve_workdir)"
    local workdir_parent
    workdir_parent=$(dirname "$workdir")

    if [[ "${CODEX:-on}" == "on" ]] && [[ -f "$HOME_DIR/.codex/config.toml" ]]; then
        if ! grep -Fq "[projects.\"$workdir\"]" "$HOME_DIR/.codex/config.toml"; then
            {
                [[ -s "$HOME_DIR/.codex/config.toml" ]] && printf '\n'
                printf '[projects."%s"]\n' "$workdir"
                printf 'trust_level = "trusted"\n'
            } >> "$HOME_DIR/.codex/config.toml"
        fi
    fi

    local args=(
        --unshare-user --uid "$(id -u)" --gid "$(id -g)"
        --unshare-pid
        --unshare-ipc
        --unshare-uts
        # No --unshare-net  — need internet access

        # Core pseudo-filesystems
        --proc /proc
        --dev /dev
        --ro-bind /sys /sys
        --tmpfs /tmp
    )
    emit_unsetenv_args args

    # System dirs — RO from host. apt install blocked naturally (can't write to /usr etc).
    emit_standard_ro_mount args /usr
    emit_standard_ro_mount args /etc
    emit_standard_ro_mount args /usr/local/bin

    # On modern Ubuntu /bin, /lib, /sbin etc are symlinks into /usr.
    # Recreate symlinks in sandbox; bind real dirs.
    for dir in /lib /lib64 /lib32 /libx32 /bin /sbin; do
        if [[ -L "$dir" ]]; then
            args+=(--symlink "$(readlink "$dir")" "$dir")
        elif [[ -d "$dir" ]]; then
            args+=(--ro-bind "$dir" "$dir")
        fi
    done

    # /run — DNS fix always; D-Bus only if enabled
    args+=(--tmpfs /run --dir "/run/user")
    [[ -d /run/systemd/resolve ]] && \
        args+=(--dir /run/systemd --bind /run/systemd/resolve /run/systemd/resolve)
    if [[ "${DBUS:-off}" == "on" ]]; then
        args+=(--bind "/run/user/$(id -u)" "/run/user/$(id -u)")
        [[ -S /run/dbus/system_bus_socket ]] && args+=(--bind /run/dbus /run/dbus)
    fi

    # Project home dir (persistent RW — survives between sessions)
    args+=(--bind "$HOME_DIR" "$SANDBOX_HOME")

    # ~/.local — tools, libs, claude binary store (RO base)
    # mise share+state overridden as RW: share has installs, state has tracked/trusted configs
    [[ -d "$HOME/.local" ]] && \
        args+=(--ro-bind "$HOME/.local" "$SANDBOX_HOME/.local")
    [[ -d "$HOME/.local/share/mise" ]] && \
        args+=(--bind "$HOME/.local/share/mise" "$SANDBOX_HOME/.local/share/mise")
    mkdir -p "$HOME/.local/state/mise"
    args+=(--bind "$HOME/.local/state/mise" "$SANDBOX_HOME/.local/state/mise")

    # Config files (RO)
    [[ -f "$HOME/.gitconfig" ]] && \
        args+=(--ro-bind "$HOME/.gitconfig" "$SANDBOX_HOME/.gitconfig")
    [[ -f "$HOME/.bash_aliases" ]] && \
        args+=(--ro-bind "$HOME/.bash_aliases" "$SANDBOX_HOME/.bash_aliases")
    [[ -d "$HOME/.config/mise" ]] && \
        args+=(--ro-bind "$HOME/.config/mise" "$SANDBOX_HOME/.config/mise")

    # X11
    if [[ "${GUI:-off}" == "on" ]] && [[ -n "${DISPLAY:-}" ]]; then
        args+=(--bind /tmp/.X11-unix /tmp/.X11-unix --setenv DISPLAY "$DISPLAY")
    fi

    # SSH keys
    if [[ "${SSH:-off}" == "on" ]] && [[ -d "$HOME/.ssh" ]]; then
        args+=(--ro-bind "$HOME/.ssh" "$SANDBOX_HOME/.ssh")
    fi

    # Project workspace path mirror (RW)
    if [[ "$workdir" == "$SANDBOX_HOME" || "$workdir" == "$SANDBOX_HOME"/* ]]; then
        mkdir -p "$HOME_DIR/$(dirname "${workdir#$SANDBOX_HOME/}")"
    else
        args+=(--dir "$workdir_parent")
    fi
    args+=(--bind "$PROJECT_DIR" "$workdir")

    # Extra mounts from project-local .bx/mounts only
    MOUNT_SRC=()
    MOUNT_MODE=()
    collect_mounts_from_file "$MOUNTS_FILE"
    emit_custom_mount_args args

    # Environment
    local project_bin="$workdir/bin"
    local sandbox_path="$project_bin:$SANDBOX_HOME/.local/share/mise/shims:$SANDBOX_HOME/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
    args+=(
        --setenv HOME "$SANDBOX_HOME"
        --setenv USER "$HOST_USER"
        --setenv LOGNAME "$HOST_USER"
        --setenv TERM "${TERM:-xterm-256color}"
        --setenv BX_PROJECT_BIN "$project_bin"
        --setenv PATH "$sandbox_path"
        --chdir "$workdir"
    )

    bwrap "${args[@]}" "$@"
}

cmd_enter() {
    run_bwrap bash --login
}

cmd_run() {
    [[ $# -eq 0 ]] && { echo "Usage: bx run <command> [args...]" >&2; exit 1; }
    # `_` is $0 placeholder; "$@" preserves argv through the login-shell hop.
    # DO NOT "simplify" back to "$*" — that flattens quotes and breaks nested bash -c.
    run_bwrap bash --login -c 'exec "$@"' _ "$@"
}

cmd_gui() {
    load_config
    local action="${1:-}"
    case "$action" in
        on)  sed -i 's/^GUI=.*/GUI=on/'  "$CONFIG_FILE"; echo "GUI enabled." ;;
        off) sed -i 's/^GUI=.*/GUI=off/' "$CONFIG_FILE"; echo "GUI disabled." ;;
        *)   grep "^GUI=" "$CONFIG_FILE" ;;
    esac
}

cmd_ssh() {
    load_config
    local action="${1:-}"
    case "$action" in
        on)  sed -i 's/^SSH=.*/SSH=on/'  "$CONFIG_FILE"; echo "SSH keys enabled." ;;
        off) sed -i 's/^SSH=.*/SSH=off/' "$CONFIG_FILE"; echo "SSH keys disabled." ;;
        *)   grep "^SSH=" "$CONFIG_FILE" ;;
    esac
}

cmd_dbus() {
    load_config
    local action="${1:-}"
    case "$action" in
        on)  sed -i 's/^DBUS=.*/DBUS=on/'  "$CONFIG_FILE"; echo "D-Bus enabled." ;;
        off) sed -i 's/^DBUS=.*/DBUS=off/' "$CONFIG_FILE"; echo "D-Bus disabled." ;;
        *)   grep "^DBUS=" "$CONFIG_FILE" ;;
    esac
}

count_mounts() {
    local count=0 line
    [[ -f "$MOUNTS_FILE" ]] || { echo "0"; return; }
    while IFS= read -r line || [[ -n "$line" ]]; do
        parse_mount_line "$line" >/dev/null || continue
        count=$((count + 1))
    done < "$MOUNTS_FILE"
    echo "$count"
}

mount_dst_exists() {
    local file="$1"
    local target_dst="$2"
    local line parsed src dst mode
    [[ -f "$file" ]] || return 1

    while IFS= read -r line || [[ -n "$line" ]]; do
        parsed="$(parse_mount_line "$line" 2>/dev/null || true)"
        [[ -z "$parsed" ]] && continue
        IFS=$'\t' read -r src dst mode <<< "$parsed"
        if [[ "$dst" == "$target_dst" ]]; then
            return 0
        fi
    done < "$file"
    return 1
}

cmd_mount() {
    load_config
    ensure_mounts_file_seeded

    local action="${1:-}"
    case "$action" in
        add)
            shift
            local src="${1:-}" dst="" mode="ro"
            [[ -n "$src" ]] || { echo "Usage: bx mount add <src> [dst] [ro|rw]" >&2; exit 1; }
            shift || true

            case "$#" in
                0)
                    dst="$src"
                    ;;
                1)
                    if [[ "$1" == "ro" || "$1" == "rw" ]]; then
                        dst="$src"
                        mode="$1"
                    else
                        dst="$1"
                    fi
                    ;;
                2)
                    dst="$1"
                    mode="$2"
                    ;;
                *)
                    echo "Usage: bx mount add <src> [dst] [ro|rw]" >&2
                    exit 1
                    ;;
            esac

            src="$(expand_path "$src")"
            dst="$(expand_path "$dst")"

            if [[ "$src" != /* || "$dst" != /* ]]; then
                echo "Mount paths must be absolute." >&2
                exit 1
            fi
            if [[ "$mode" != "ro" && "$mode" != "rw" ]]; then
                echo "Mode must be ro or rw." >&2
                exit 1
            fi
            if mount_dst_exists "$MOUNTS_FILE" "$dst"; then
                echo "Mount destination '$dst' already exists. Remove it first with: bx mount rm $dst" >&2
                exit 1
            fi

            if [[ "$dst" == "$src" && "$mode" == "ro" ]]; then
                echo "$src" >> "$MOUNTS_FILE"
            elif [[ "$mode" == "ro" ]]; then
                echo "$src $dst" >> "$MOUNTS_FILE"
            else
                echo "$src $dst rw" >> "$MOUNTS_FILE"
            fi

            echo "Mount added."
            if [[ "$dst" == "$SANDBOX_HOME" || "$dst" == "$SANDBOX_HOME"/* ]]; then
                local target="$HOME_DIR${dst#$SANDBOX_HOME}"
                if [[ "$src" == */ ]]; then
                    mkdir -p "$target"
                else
                    mkdir -p "$(dirname "$target")"
                fi
            fi
            ;;
        rm)
            local dst="${2:-}"
            if [[ -z "$dst" || $# -ne 2 ]]; then
                echo "Usage: bx mount rm <dst>" >&2
                exit 1
            fi
            dst="$(expand_path "$dst")"

            local tmp
            tmp=$(mktemp)
            local line parsed src parsed_dst mode
            while IFS= read -r line || [[ -n "$line" ]]; do
                parsed="$(parse_mount_line "$line" 2>/dev/null || true)"
                if [[ -z "$parsed" ]]; then
                    echo "$line" >> "$tmp"
                    continue
                fi
                IFS=$'\t' read -r src parsed_dst mode <<< "$parsed"
                [[ "$parsed_dst" == "$dst" ]] && continue
                echo "$line" >> "$tmp"
            done < "$MOUNTS_FILE"
            mv "$tmp" "$MOUNTS_FILE"
            echo "Mount(s) removed for destination: $dst"
            ;;
        list)
            cat "$MOUNTS_FILE"
            ;;
        *)
            echo "Usage:"
            echo "  bx mount add <src> [dst] [ro|rw]"
            echo "  bx mount rm <dst>"
            echo "  bx mount list"
            ;;
    esac
}

cmd_claude() {
    load_config
    local action="${1:-}"
    case "$action" in
        on)  sed -i 's/^CLAUDE=.*/CLAUDE=on/'  "$CONFIG_FILE"; echo "Claude sync enabled." ;;
        off) sed -i 's/^CLAUDE=.*/CLAUDE=off/' "$CONFIG_FILE"; echo "Claude sync disabled." ;;
        *)   grep "^CLAUDE=" "$CONFIG_FILE" || echo "CLAUDE=on" ;;
    esac
}

cmd_codex() {
    load_config
    local action="${1:-}"
    case "$action" in
        on)  sed -i 's/^CODEX=.*/CODEX=on/'  "$CONFIG_FILE"; echo "Codex sync enabled." ;;
        off) sed -i 's/^CODEX=.*/CODEX=off/' "$CONFIG_FILE"; echo "Codex sync disabled." ;;
        *)   grep "^CODEX=" "$CONFIG_FILE" || echo "CODEX=on" ;;
    esac
}

cmd_status() {
    load_config
    local workdir
    workdir="$(resolve_workdir)"
    echo "Project: $PROJECT_DIR"
    echo "Workdir: $workdir"
    echo "GUI:     ${GUI:-off}"
    echo "SSH:     ${SSH:-off}"
    echo "D-Bus:   ${DBUS:-off}"
    echo "Claude:  ${CLAUDE:-on}"
    echo "Codex:   ${CODEX:-on}"
    echo "Mounts:  $(count_mounts)"
    echo "Home:    $HOME_DIR ($(du -sh "$HOME_DIR" 2>/dev/null | cut -f1) used)"
}

cmd_destroy() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo "No .bx/ found." >&2; exit 1
    fi
    read -rp "Delete .bx/ for '$(basename "$PROJECT_DIR")'? [y/N] " confirm
    [[ "$confirm" =~ ^[yY]$ ]] || exit 0
    rm -rf "$CONFIG_DIR"
    echo "Destroyed."
}

case "${1:-}" in
    init)    cmd_init ;;
    enter)   cmd_enter ;;
    run)     shift; cmd_run "$@" ;;
    gui)     shift; cmd_gui "$@" ;;
    ssh)     shift; cmd_ssh "$@" ;;
    dbus)    shift; cmd_dbus "$@" ;;
    mount)   shift; cmd_mount "$@" ;;
    claude)  shift; cmd_claude "$@" ;;
    codex)   shift; cmd_codex "$@" ;;
    status)  cmd_status ;;
    destroy) cmd_destroy ;;
    *)
        echo "bx — project-aware bwrap sandbox"
        echo ""
        echo "Commands:"
        echo "  init           Initialize sandbox for current project"
        echo "  enter          Shell into sandbox"
        echo "  run CMD        Run a command inside sandbox"
        echo "  gui [on|off]   Toggle X11 forwarding"
        echo "  ssh [on|off]   Toggle ~/.ssh mount (read-only)"
        echo "  dbus [on|off]  Toggle D-Bus session bus (default: off)"
        echo "  mount ...      Manage extra mounts (add/rm/list)"
        echo "  claude [on|off] Toggle Claude auth/config sync"
        echo "  codex [on|off]  Toggle Codex auth/config sync"
        echo "  status         Show sandbox config"
        echo "  destroy        Remove .bx/ (project files are safe)"
        ;;
esac
