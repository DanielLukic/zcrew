#!/usr/bin/env bash
# zcrew-managed
set -euo pipefail
_zcrew_primary_lib_dir="$(dirname "${BASH_SOURCE[0]}")/../lib"
if [[ -f "$_zcrew_primary_lib_dir/multiplexer.sh" ]]; then source "$_zcrew_primary_lib_dir/multiplexer.sh"; fi

# Hardened PROJECT_DIR resolver — 4-rule lookup with stateful/discovery guard.
#
# Rules (in order):
#   1. ZCREW_PROJECT_DIR env: validate dir exists + realpath.
#      Ignored entirely when BX_INSIDE=1 (host paths don't translate inside sandbox).
#   2. Walk up from PWD looking for .zcrew/.
#      If .git is a FILE (linked worktree), redirect via
#      git rev-parse --path-format=absolute --git-common-dir → strip /.git
#      → main project root.
#   3. If inside git (but no .zcrew/ found): return git common root
#      (rev-parse --git-common-dir, strip /.git, realpath).
#   4. PWD fallback (realpath PWD).
#
# ALWAYS realpath() the final result.
#
# Semantics:
#   for_op=discovery (init/install/usage): return whatever rule resolves.
#   for_op=stateful (spawn/send/claim/list/sync/register/unregister/
#                    rename/close/reply/gc):
#     require .zcrew/ at the resolved root. If missing, hard-error.
#
# Cached per process: first call sets _RESOLVED_PROJECT_DIR.
is_zcrew_project_root() {
  local root="$1"
  [[ -d "$root/.zcrew" ]]
}

resolve_project_dir_from_path_if_resolvable() {
  local start_path="${1:-}"
  local dir=""
  local git_dir=""
  local git_common_dir=""
  local main_root=""

  [[ -n "$start_path" ]] || return 1
  if [[ -d "$start_path" ]]; then
    dir="$(realpath "$start_path" 2>/dev/null || true)"
  elif [[ -e "$start_path" ]]; then
    dir="$(dirname "$(realpath "$start_path")")"
  else
    return 1
  fi
  [[ -n "$dir" ]] || return 1
  git_dir="$dir"

  while true; do
    if is_zcrew_project_root "$dir"; then
      if [[ -f "$dir/.git" ]]; then
        git_common_dir="$(git -C "$dir" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"
        if [[ -n "$git_common_dir" ]]; then
          main_root="${git_common_dir%/.git}"
          if is_zcrew_project_root "$main_root"; then
            realpath "$main_root"
            return 0
          fi
        fi
      fi
      realpath "$dir"
      return 0
    fi
    if [[ "$dir" == "/" ]]; then
      break
    fi
    dir="$(dirname "$dir")"
  done

  git_common_dir="$(git -C "$git_dir" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"
  if [[ -n "$git_common_dir" ]]; then
    main_root="${git_common_dir%/.git}"
    if is_zcrew_project_root "$main_root"; then
      realpath "$main_root"
      return 0
    fi
  fi

  return 1
}

resolve_project_dir_from_pwd_if_resolvable() {
  resolve_project_dir_from_path_if_resolvable "$PWD"
}

resolve_project_dir() {
  local for_op="${1:-stateful}"

  # Return cached result if already resolved.
  if [[ -n "${_RESOLVED_PROJECT_DIR:-}" ]]; then
    if [[ "$for_op" == "stateful" && ! -d "$_RESOLVED_PROJECT_DIR/.zcrew" ]]; then
      echo "zcrew: no zcrew project here. Run \`zcrew init\` or \`zcrew install .\` to create one." >&2
      exit 1
    fi
    printf '%s\n' "$_RESOLVED_PROJECT_DIR"
    return 0
  fi

  local candidate=""

  # Rule 1: ZCREW_PROJECT_DIR env — ignored inside sandbox.
  if [[ "${BX_INSIDE:-0}" != "1" && -n "${ZCREW_PROJECT_DIR:-}" && -d "$ZCREW_PROJECT_DIR" ]]; then
    candidate="$(realpath "$ZCREW_PROJECT_DIR")"
    local cwd_candidate=""
    if cwd_candidate="$(resolve_project_dir_from_pwd_if_resolvable)"; then
      if [[ "$cwd_candidate" != "$candidate" ]]; then
        {
          echo "zcrew: ZCREW_PROJECT_DIR points at a different project than the current working directory."
          echo "zcrew: env project: $candidate"
          echo "zcrew: cwd project: $cwd_candidate"
          echo "zcrew: hint: ZCREW_PROJECT_DIR is likely set in your shell profile or parent shell."
        } >&2
        exit 1
      fi
    fi
  fi

  # Rule 2: Walk up from PWD looking for .zcrew/.
  if [[ -z "$candidate" ]]; then
    candidate="$(resolve_project_dir_from_pwd_if_resolvable || true)"
  fi

  # Rule 3: Git common root (if inside a repo but no .zcrew/ found).
  if [[ -z "$candidate" ]]; then
    local git_common_dir
    git_common_dir="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"
    if [[ -n "$git_common_dir" ]]; then
      candidate="$(realpath "${git_common_dir%/.git}")"
    fi
  fi

  # Rule 4: PWD fallback.
  if [[ -z "$candidate" ]]; then
    candidate="$(realpath "$PWD")"
  fi

  # Stateful guard: .zcrew/ must exist at the resolved root.
  if [[ "$for_op" == "stateful" && ! -d "$candidate/.zcrew" ]]; then
    echo "zcrew: no zcrew project here. Run \`zcrew init\` or \`zcrew install .\` to create one." >&2
    exit 1
  fi

  # Cache and return.
  _RESOLVED_PROJECT_DIR="$candidate"
  printf '%s\n' "$candidate"
}

# Lazy: set on first call to resolve_project_dir.
PROJECT_DIR=""
_resolve_and_set_project_dir() {
  local for_op="${1:-stateful}"
  PROJECT_DIR="$(resolve_project_dir "$for_op")"
  STATE_DIR="$PROJECT_DIR/.zcrew"
  REGISTRY_FILE="$STATE_DIR/registry.json"
  LOCK_FILE="$STATE_DIR/registry.lock"
  SPAWN_DIR="$STATE_DIR/spawn"
  AUDIT_FILE="$STATE_DIR/audit.log"
  BX_DIR="$PROJECT_DIR/.bx"
}




resolve_lib_dir() {
  local project_root="${1:-$PROJECT_DIR}"
  if [[ -z "$project_root" ]]; then
    project_root="$(resolve_project_dir discovery)"
  fi
  local project_lib="$(realpath "$project_root/.zcrew/lib")"
  if [[ ! -d "$project_lib" ]]; then
    echo "zcrew: no zcrew lib dir found at $project_lib" >&2
    echo "Run .zcrew/bin/zcrew install <source> <target> to repair." >&2
    exit 1
  fi
  printf '%s\n' "$project_lib"
}
STATE_DIR=""
REGISTRY_FILE=""
LOCK_FILE=""
SPAWN_DIR=""
AUDIT_FILE=""
BX_DIR=""
CURRENT_SUBCMD="main"
ZCREW_AUTO_SYNC="${ZCREW_AUTO_SYNC:-1}"
ZCREW_PROJECT_READY=0
REPLY_CMD='zcrew reply "<your message>"'

if [[ "${ZCREW_DEBUG:-0}" == "1" ]]; then
  PS4='+[$(date +%H:%M:%S.%N) $$ ${FUNCNAME[0]:-main}]+ '
  set -x
fi

logger() {
  local audit_rotate_bytes=1048576
  local subcmd="${1:-main}"
  local level="${2:-info}"
  shift 2 || true
  local msg="$*"
  [[ -d "$STATE_DIR" ]] || return 0
  local audit_size
  audit_size=$(stat -c%s "$AUDIT_FILE" 2>/dev/null || printf '0\n')
  if [[ "$audit_size" -gt "$audit_rotate_bytes" ]]; then
    rm -f "$AUDIT_FILE.1"
    mv "$AUDIT_FILE" "$AUDIT_FILE.1"
  fi
  printf '%s\t%s\t%s\t%s\t%s\n' "$(date +%Y-%m-%dT%H:%M:%S.%N%z)" "$$" "$subcmd" "$level" "$msg" >> "$AUDIT_FILE"
}

fail_not_initialized() {
  echo "zcrew: no zcrew project here. Run `zcrew init` or `zcrew install .` to create one." >&2
  exit 1
}

require_project() {
  _resolve_and_set_project_dir "stateful"
  [[ -d "$STATE_DIR" ]] || fail_not_initialized
  if [[ "$ZCREW_PROJECT_READY" != "1" ]]; then
    if [[ "$ZCREW_AUTO_SYNC" == "1" ]]; then
      logger "$CURRENT_SUBCMD" "info" "auto-sync begin"
      reconcile_registry_with_live_panes "true"
      logger "$CURRENT_SUBCMD" "info" "auto-sync end"
    fi
    ZCREW_PROJECT_READY=1
  fi
}

remove_zcrew_sessionstart_hook() {
  local target_dir="${1:-.}"
  local settings_dir="$target_dir/.claude"
  local settings_file="$settings_dir/settings.json"
  local hook_command='${CLAUDE_PROJECT_DIR}/.claude/hooks/zcrew-register.sh'
  [[ -f "$settings_file" ]] || return 1

  local tmp="$settings_file.tmp.$$"
  jq --arg hook "$hook_command" '
    .hooks = (.hooks // {})
    | .hooks.SessionStart = (
        (.hooks.SessionStart // [])
        | map(
            .hooks = ((.hooks // []) | map(select(.type != "command" or .command != $hook)))
          )
        | map(select((.hooks // []) | length > 0))
      )
    | if (.hooks.SessionStart | length) == 0 then
        .hooks |= del(.SessionStart)
      else
        .
      end
    | if ((.hooks | keys | length) == 0) then
        del(.hooks)
      else
        .
      end
  ' "$settings_file" > "$tmp"

  local before after
  before=$(cat "$settings_file")
  after=$(cat "$tmp")
  if [[ "$before" == "$after" ]]; then
    rm -f "$tmp"
    return 1
  fi

  mv "$tmp" "$settings_file"
  return 0
}

mount_line_dst() {
  local raw="$1"
  local cleaned="$raw"
  cleaned="${cleaned#"${cleaned%%[![:space:]]*}"}"
  cleaned="${cleaned%"${cleaned##*[![:space:]]}"}"
  [[ -z "$cleaned" || "$cleaned" == \#* ]] && return 1

  if [[ "$cleaned" == *:* && "$cleaned" != *" "* && "$cleaned" != *$'\t'* ]]; then
    local src dst rest
    IFS=':' read -r src dst rest <<< "$cleaned"
    [[ -n "${dst:-}" ]] || return 1
    printf '%s\n' "$dst"
    return 0
  fi

  local parts=()
  read -r -a parts <<< "$cleaned"
  case "${#parts[@]}" in
    1) printf '%s\n' "${parts[0]}" ;;
    2)
      if [[ "${parts[1]}" == "ro" || "${parts[1]}" == "rw" ]]; then
        printf '%s\n' "${parts[0]}"
      else
        printf '%s\n' "${parts[1]}"
      fi
      ;;
    *)
      printf '%s\n' "${parts[1]}"
      ;;
  esac
}

resolve_bx_workdir_for_target() {
  local target_dir="$1"
  local target_abs config_file workdir
  target_abs="$(realpath "$target_dir")"
  config_file="$target_dir/.bx/config"
  workdir="$target_abs"
  if [[ -f "$config_file" ]]; then
    workdir="$(awk -F= '/^WORKDIR=/{print substr($0,9); exit}' "$config_file")"
    [[ -n "$workdir" ]] || workdir="$target_abs"
  fi
  printf '%s\n' "$workdir"
}

resolve_bx_sandbox_home() {
  local sandbox_home
  sandbox_home="$(getent passwd "$(id -u)" | cut -d: -f6)"
  sandbox_home="${sandbox_home:-$HOME}"
  printf '%s\n' "$sandbox_home"
}

write_managed_sandbox_gitignore() {
  local target_dir="$1"
  local git_config_dir="$target_dir/.bx/home/.config/git"
  local ignore_file="$git_config_dir/ignore"
  local gitconfig_file="$target_dir/.bx/home/.gitconfig"

  mkdir -p "$git_config_dir"
  cat > "$ignore_file" <<'EOF'
# zcrew-managed
.bx/
.zcrew/
.config/mise.toml
.agents/skills/zcrew/
.claude/skills/zcrew
.claude/skills/zspawn
.claude/skills/zsend
.claude/skills/zpanes
.claude/skills/zsync
.claude/skills/zname
.claude/skills/zclose
.pi/skills/zcrew
.pi/skills/zspawn
.pi/skills/zsend
.pi/skills/zpanes
.pi/skills/zsync
.pi/skills/zname
.pi/skills/zclose
.codex/skills/zcrew/
bin/zcrew
bin/bx
bin/ix
EOF

  if [[ ! -f "$gitconfig_file" ]] || [[ "$(head -n 1 "$gitconfig_file" 2>/dev/null || true)" == '# zcrew-managed' ]]; then
    cat > "$gitconfig_file" <<'EOF'
# zcrew-managed
[core]
	excludesfile = ~/.config/git/ignore
EOF
  fi
}

write_managed_bx_mounts() {
  local target_dir="$1"
  local bx_dir="$target_dir/.bx"
  [[ -d "$bx_dir" ]] || return 1

  local mounts_file="$bx_dir/mounts"
  local target_abs workdir sandbox_home mx_sock_dir tmp before after in_managed=false line
  local pair_count=0
  local lib_dir local_lib_abs mount_bin_src mount_lib_src mode_note
  target_abs="$(realpath "$target_dir")"
  workdir="$(resolve_bx_workdir_for_target "$target_dir")"
  sandbox_home="$(resolve_bx_sandbox_home)"
  mx_sock_dir="$(mx_socket_dir)"
  mount_bin_src="$target_abs/.zcrew/bin"
  mount_lib_src="$target_abs/.zcrew/lib"
  mode_note="# install-mode: local (.zcrew/bin + .zcrew/lib)"

  mkdir -p "$bx_dir"
  [[ -f "$mounts_file" ]] || : > "$mounts_file"

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == '# zcrew-managed begin' ]]; then
      if [[ "$in_managed" == "true" ]]; then
        echo "warning: .bx/mounts has invalid zcrew-managed markers; preserving existing file: $mounts_file" >&2
        return 1
      fi
      in_managed=true
      continue
    fi
    if [[ "$line" == '# zcrew-managed end' ]]; then
      if [[ "$in_managed" != "true" ]]; then
        echo "warning: .bx/mounts has invalid zcrew-managed markers; preserving existing file: $mounts_file" >&2
        return 1
      fi
      in_managed=false
      pair_count=$((pair_count + 1))
    fi
  done < "$mounts_file"

  if [[ "$in_managed" == "true" ]] || [[ "$pair_count" -gt 1 ]]; then
    echo "warning: .bx/mounts has invalid zcrew-managed markers; preserving existing file: $mounts_file" >&2
    return 1
  fi

  in_managed=false
  tmp="$mounts_file.tmp.$$"
  : > "$tmp"
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == '# zcrew-managed begin' ]]; then
      in_managed=true
      continue
    fi
    if [[ "$line" == '# zcrew-managed end' ]]; then
      in_managed=false
      continue
    fi
    if [[ "$in_managed" == "true" ]]; then
      continue
    fi
    printf '%s\n' "$line" >> "$tmp"
  done < "$mounts_file"

  cat >> "$tmp" <<EOF
# zcrew-managed begin
# Managed by zcrew install; source paths are selected at install time.
$mode_note
$mx_sock_dir $mx_sock_dir rw
$mount_bin_src $workdir/.zcrew/bin ro
$mount_lib_src $workdir/.zcrew/lib ro
$target_abs/.config/mise.toml $workdir/.config/mise.toml ro
$target_abs/.bx/config $workdir/.bx/config ro
$target_abs/.bx/mounts $workdir/.bx/mounts ro
$target_abs/.bx/.gitignore $workdir/.bx/.gitignore ro
$target_abs/.bx/home/.config/git/ignore $workdir/.bx/home/.config/git/ignore ro
$target_abs/.bx/home/.config/git/ignore $sandbox_home/.config/git/ignore ro
# zcrew-managed end
EOF

  before="$(cat "$mounts_file")"
  after="$(cat "$tmp")"
  if [[ "$before" == "$after" ]]; then
    rm -f "$tmp"
    return 1
  fi
  mv "$tmp" "$mounts_file"
  return 0
}

ensure_bx_managed_mounts() {
  write_managed_bx_mounts "$@"
}

ensure_registry_files() {
  mkdir -p "$SPAWN_DIR"
  : > "$LOCK_FILE"
  if [[ ! -f "$REGISTRY_FILE" ]]; then
    printf '{"version":1,"panes":{}}\n' > "$REGISTRY_FILE"
  fi
}

ensure_gitignore_lines() {
  local file="$1"
  shift
  local line

  mkdir -p "$(dirname "$file")"
  [[ -f "$file" ]] || : > "$file"
  for line in "$@"; do
    if ! grep -Fxq "$line" "$file"; then
      printf '%s\n' "$line" >> "$file"
    fi
  done
}

ensure_team_conf_template() {
  local target_dir="$1"
  local team_file="$target_dir/.zcrew/team.conf"

  [[ -f "$team_file" ]] && return 0

  mkdir -p "$(dirname "$team_file")"
  cat > "$team_file" <<'EOF'
# Team composition — read by the orchestrator at session start.
# name  agent  model  role
claudio  claude  sonnet         assistant / researcher
sam      codex   -              reviewer
sparky   codex   gpt-5.3-codex  implementer
piper    pi      glm-5.1        optional alternative model agent
EOF
}

zcrew_owned_bin_files() {
  printf '%s\n' zcrew bx ix
}

zcrew_owned_lib_files() {
  printf '%s\n' tell mcp_server.py multiplexer.sh pi-zcrew-ext.ts stop-hook.sh codex-auto-reply.mjs launchers/claude.sh launchers/codex.sh launchers/pi.sh
}

keep_symlink_target_for() {
  local rel="$1"
  case "$rel" in
    bin/*) printf '../.zcrew/bin/%s\n' "${rel#bin/}" ;;
    lib/zcrew/tell) printf '../../.zcrew/lib/tell\n' ;;
    lib/zcrew/mcp_server.py) printf '../../.zcrew/lib/mcp_server.py\n' ;;
    lib/zcrew/multiplexer.sh) printf '../../.zcrew/lib/multiplexer.sh\n' ;;
    lib/zcrew/pi-zcrew-ext.ts) printf '../../.zcrew/lib/pi-zcrew-ext.ts\n' ;;
    lib/zcrew/stop-hook.sh) printf '../../.zcrew/lib/stop-hook.sh\n' ;;
    lib/zcrew/codex-auto-reply.mjs) printf '../../.zcrew/lib/codex-auto-reply.mjs\n' ;;
    lib/zcrew/launchers/*) printf '../../../.zcrew/lib/launchers/%s\n' "${rel#lib/zcrew/launchers/}" ;;
    *) return 1 ;;
  esac
}

owned_source_path_for() {
  local src_root="$1"
  local rel="$2"
  case "$rel" in
    bin/*) printf '%s/.zcrew/bin/%s\n' "$src_root" "${rel#bin/}" ;;
    lib/zcrew/*) printf '%s/.zcrew/lib/%s\n' "$src_root" "${rel#lib/zcrew/}" ;;
    *) return 1 ;;
  esac
}

is_keep_symlink() {
  local file="$1"
  local root="$2"
  local rel expected
  rel="${file#"$root"/}"
  expected="$(keep_symlink_target_for "$rel")" || return 1
  [[ -L "$file" && "$(readlink "$file")" == "$expected" ]]
}

is_zcrew_owned_file() {
  local path="$1"
  local rel="$2"
  [[ -f "$path" ]] || return 1
  if grep -q '^# zcrew-managed' "$path"; then
    case "$rel" in
      lib/zcrew/launchers/claude.sh) grep -q '^# zcrew launcher: claude$' "$path" && return 0 ;;
      lib/zcrew/launchers/codex.sh) grep -q '^# zcrew launcher: codex$' "$path" && return 0 ;;
      lib/zcrew/launchers/pi.sh) grep -q '^# zcrew launcher: pi$' "$path" && return 0 ;;
      *) return 0 ;;
    esac
  fi
  case "$rel" in
    bin/zcrew)
      grep -q 'CURRENT_SUBCMD' "$path"
      ;;
    bin/bx)
      grep -q 'export BX_INSIDE=1' "$path" && { grep -q 'BX_UNSETENV_VARS' "$path" || grep -q 'bx-bashrc-version' "$path"; }
      ;;
    bin/ix)
      grep -q 'IX_INSIDE' "$path"
      ;;
    lib/zcrew/tell)
      grep -q '# zcrew-managed' "$path"
      ;;
    lib/zcrew/mcp_server.py)
      grep -q 'zcrew MCP server' "$path"
      ;;
    lib/zcrew/multiplexer.sh)
      grep -q '^# zcrew-managed$' "$path" && grep -q '^_mx_ensure_init()' "$path"
      ;;
    lib/zcrew/pi-zcrew-ext.ts)
      grep -q 'pi-native zcrew extension' "$path"
      ;;
    lib/zcrew/stop-hook.sh)
      grep -q '^# zcrew stop-hook' "$path"
      ;;
    lib/zcrew/codex-auto-reply.mjs)
      grep -q 'ZCREW_CODEX_WS_URL' "$path"
      ;;
    lib/zcrew/launchers/claude.sh)
      grep -q '^# zcrew launcher: claude$' "$path" || grep -q -- '--dangerously-skip-permissions' "$path"
      ;;
    lib/zcrew/launchers/codex.sh)
      grep -q '^# zcrew launcher: codex$' "$path" || grep -q 'danger-full-access' "$path"
      ;;
    lib/zcrew/launchers/pi.sh)
      grep -q '^# zcrew launcher: pi$' "$path" || grep -q 'PI_PACKAGE_DIR' "$path"
      ;;
    *)
      return 1
      ;;
  esac
}

create_keep_symlinks() {
  local root="$1"
  local rel dst expected
  mkdir -p "$root/bin" "$root/lib/zcrew/launchers"
  while IFS= read -r rel; do
    dst="$root/bin/$rel"
    expected="$(keep_symlink_target_for "bin/$rel")"
    if [[ -e "$dst" && ! -L "$dst" ]]; then
      echo "warning: keeping existing non-symlink at bin/$rel" >&2
      continue
    fi
    ln -sf "$expected" "$dst"
  done < <(zcrew_owned_bin_files)
  while IFS= read -r rel; do
    dst="$root/lib/zcrew/$rel"
    expected="$(keep_symlink_target_for "lib/zcrew/$rel")"
    mkdir -p "$(dirname "$dst")"
    if [[ -e "$dst" && ! -L "$dst" ]]; then
      echo "warning: keeping existing non-symlink at lib/zcrew/$rel" >&2
      continue
    fi
    ln -sf "$expected" "$dst"
  done < <(zcrew_owned_lib_files)
}

verify_managed_layout() {
  local root="$1"
  local rel
  while IFS= read -r rel; do
    [[ -x "$root/.zcrew/bin/$rel" ]] || return 1
  done < <(zcrew_owned_bin_files)
  while IFS= read -r rel; do
    case "$rel" in
      *.ts|multiplexer.sh) [[ -r "$root/.zcrew/lib/$rel" ]] || return 1 ;;
      *)    [[ -x "$root/.zcrew/lib/$rel" ]] || return 1 ;;
    esac
  done < <(zcrew_owned_lib_files)
}

copy_managed_layout() {
  local src_root="$1"
  local target_root="$2"
  mkdir -p "$target_root/.zcrew/bin" "$target_root/.zcrew/lib/launchers"
  local rel
  while IFS= read -r rel; do
    cp "$src_root/.zcrew/bin/$rel" "$target_root/.zcrew/bin/$rel"
    chmod +x "$target_root/.zcrew/bin/$rel"
  done < <(zcrew_owned_bin_files)
  while IFS= read -r rel; do
    mkdir -p "$(dirname "$target_root/.zcrew/lib/$rel")"
    cp "$src_root/.zcrew/lib/$rel" "$target_root/.zcrew/lib/$rel"
    case "$rel" in
      *.ts|multiplexer.sh) chmod 644 "$target_root/.zcrew/lib/$rel" ;;
      *) chmod +x "$target_root/.zcrew/lib/$rel" ;;
    esac
  done < <(zcrew_owned_lib_files)
}

detect_install_source() {
  local self clone_src
  self="$(readlink -f "${BASH_SOURCE[0]}")"
  clone_src="$(dirname "$(dirname "$(dirname "$self")")")"
  if [[ -f "$clone_src/.zcrew/bin/zcrew" && -f "$clone_src/.zcrew/lib/mcp_server.py" ]]; then
    printf 'clone|%s|%s\n' "$self" "$clone_src"
    return 0
  fi
  echo "zcrew: cannot determine install source for $self" >&2
  echo "zcrew: expected a clone checkout with .zcrew/bin/zcrew and .zcrew/lib/mcp_server.py" >&2
  exit 1
}



write_managed_mise_floor() {
  local target_dir="$1"
  local config_dir="$target_dir/.config"
  local mise_file="$config_dir/mise.toml"

  mkdir -p "$config_dir"
  cat > "$mise_file" <<EOF
# Managed by zcrew install — do not edit manually.
# Project-specific overrides go in .mise.toml (higher precedence).
[tools]
node = "lts"

[env]
_.path = [".zcrew/bin"]
EOF
}

registry_write_jq() {
  local jq_filter="$1"
  shift

  ensure_registry_files
  logger "$CURRENT_SUBCMD" "info" "registry_write_jq begin"
  local tmp
  tmp=$(mktemp "$STATE_DIR/registry.json.tmp.XXXXXX")
  (
    flock -x 9
    jq "$jq_filter" "$@" "$REGISTRY_FILE" > "$tmp"
    mv "$tmp" "$REGISTRY_FILE"
  ) 9>"$LOCK_FILE"
  logger "$CURRENT_SUBCMD" "info" "registry_write_jq end"
}

cmd_init() {
  CURRENT_SUBCMD="init"
  _resolve_and_set_project_dir "discovery"
  mkdir -p "$SPAWN_DIR"
  : > "$LOCK_FILE"
  if [[ ! -f "$REGISTRY_FILE" ]]; then
    printf '{"version":1,"panes":{}}\n' > "$REGISTRY_FILE"
  fi
  logger "init" "info" "entry cwd=$PWD"
  echo "Initialized .zcrew/ at $PROJECT_DIR"
}

cmd_register() {
  CURRENT_SUBCMD="register"
  require_project
  ensure_registry_files

  local name="${1:-}"
  [[ -n "$name" ]] || { echo "Usage: zcrew register <name> [--paneId X] [--sessionId Y] [--agent A] [--cwd P] [--pid N] [--status S]" >&2; exit 1; }
  shift || true

  local pane_id=""
  pane_id="$( (_MX_BACKEND_CHECKED=1 mx_pane_id) 2>/dev/null || echo)"
  local session_id=""
  local agent="claude"
  local cwd="$PWD"
  local pid="$$"
  local status="alive"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --paneId) pane_id="${2:-}"; shift 2 ;;
      --sessionId) session_id="${2:-}"; shift 2 ;;
      --agent) agent="${2:-}"; shift 2 ;;
      --cwd) cwd="${2:-}"; shift 2 ;;
      --pid) pid="${2:-}"; shift 2 ;;
      --status) status="${2:-}"; shift 2 ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  local now
  now=$(date +%s)

  # If another non-matching key already points to this paneId, this is a
  # duplicate-register attempt (typically from the SessionStart hook firing
  # after a named spawn). No-op instead of clobbering the real name.
  local existing
  existing=$(jq -r --arg name "$name" --arg paneId "$pane_id" '
    .panes // {}
    | to_entries
    | map(select((.value.paneId // "") == $paneId and .key != $name))
    | .[0].key // empty
  ' "$REGISTRY_FILE")
  if [[ -n "$existing" ]]; then
    logger "register" "info" "skip duplicate name=$name paneId=$pane_id existing=$existing"
    echo "registered: $existing (existing for paneId=$pane_id)"
    return 0
  fi

  registry_write_jq '
    .version = 1
    | .panes = (.panes // {})
    | .panes[$name] = {
        paneId: $paneId,
        sessionId: (if $sessionId == "" then null else $sessionId end),
        agent: $agent,
        projectDir: $projectDir,
        cwd: $cwd,
        pid: (if $pid == "" then null else ($pid|tonumber) end),
        lastSeen: ($now|tonumber),
        status: $status
      }
  ' \
    --arg name "$name" \
    --arg paneId "$pane_id" \
    --arg sessionId "$session_id" \
    --arg agent "$agent" \
    --arg projectDir "$PROJECT_DIR" \
    --arg cwd "$cwd" \
    --arg pid "$pid" \
    --arg now "$now" \
    --arg status "$status"

  echo "registered: $name"
}

cmd_spawn() {
  CURRENT_SUBCMD="spawn"
  local agent=""
  local name=""
  local model=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --model)
        model="${2:-}"
        [[ -n "$model" ]] || { echo "Usage: zcrew spawn [--model <model>] <agent> <name>" >&2; exit 1; }
        shift 2
        ;;
      --*)
        echo "zcrew: unknown option '$1'" >&2
        exit 1
        ;;
      *)
        if [[ -z "$agent" ]]; then
          agent="$1"
        elif [[ -z "$name" ]]; then
          name="$1"
        else
          echo "Usage: zcrew spawn [--model <model>] <agent> <name>" >&2
          exit 1
        fi
        shift
        ;;
    esac
  done
  [[ -n "$agent" && -n "$name" ]] || { echo "Usage: zcrew spawn [--model <model>] <agent> <name>" >&2; exit 1; }

  _resolve_and_set_project_dir "stateful"

  # CLI --model wins. Otherwise resolve from .zcrew/team.conf row:
  #   name agent model role  (whitespace-delimited; "-" or empty = no override)
  if [[ -z "$model" ]]; then
    local team_file="$PROJECT_DIR/.zcrew/team.conf"
    if [[ -f "$team_file" ]]; then
      local team_model
      team_model="$(awk -v n="$name" '
        /^[[:space:]]*#/ { next }
        NF < 3 { next }
        $1 == n { print $3; exit }
      ' "$team_file")"
      if [[ -n "$team_model" && "$team_model" != "-" ]]; then
        model="$team_model"
      fi
    fi
  fi

  # STEP 1: Minimal spawn — just open a new pane. No bx, no wrapper, no
  # sentinel, no registry. Baby steps. Layers added back in subsequent steps.
  logger "spawn" "info" "entry agent=$agent name=$name model=${model:-} cwd=$PWD ZELLIJ_SESSION_NAME=${ZELLIJ_SESSION_NAME:-} ZELLIJ_PANE_ID=${ZELLIJ_PANE_ID:-} MUX_PANE_ID=$( (_MX_BACKEND_CHECKED=1 mx_pane_id) 2>/dev/null || echo)"
  mx_require_session
  require_project

  claim_main_for_send >/dev/null

  local existing_pane
  existing_pane=$(jq -r --arg n "$name" '.panes[$n].paneId // empty' "$REGISTRY_FILE")
  if [[ -n "$existing_pane" ]]; then
    echo "zcrew: pane '$name' already exists (pane=$existing_pane) — close it first with: zcrew close $name" >&2
    exit 1
  fi

  if [[ ! -d "$BX_DIR" ]]; then
    local missing=()
    [[ -d "$BX_DIR" ]] || missing+=('.bx/')
    echo "zcrew: missing ${missing[*]} in $PROJECT_DIR — run: zcrew install ." >&2
    exit 1
  fi
  ensure_bx_managed_mounts "$PROJECT_DIR" >/dev/null 2>&1 || true
  ensure_registry_files

  logger "spawn" "info" "calling multiplexer new-pane"

  # Built-ins use per-agent launchers; unknown agents fall back to a generic
  # `bx run <agent>` command. The outer bash wrapper sets an EXIT trap so when
  # the agent (and bx) exit, the registry entry is auto-removed.
  local zcrew_abs
  zcrew_abs="$(command -v zcrew 2>/dev/null || true)"
  [[ -n "$zcrew_abs" && -x "$zcrew_abs" ]] || {
    echo "zcrew: cannot find zcrew binary on PATH for worker EXIT trap; spawn aborted" >&2
    return 1
  }
  zcrew_abs="$(realpath "$zcrew_abs")"
  local trap_cmd="trap '\"$zcrew_abs\" unregister \"$name\"' EXIT"
  local launch_cmd
  local launcher_path="$PROJECT_DIR/.zcrew/lib/launchers/$agent.sh"
  if [[ -x "$launcher_path" ]]; then
    launch_cmd=$(printf '%q' "$launcher_path")
  else
    local lib_dir=""
    if [[ -d "$PROJECT_DIR/.zcrew/lib" ]]; then
      lib_dir="$(resolve_lib_dir)"
    fi
    if [[ -n "$lib_dir" && -x "$lib_dir/launchers/$agent.sh" ]]; then
      launch_cmd=$(printf '%q' "$lib_dir/launchers/$agent.sh")
    else
      launch_cmd="bx run $(printf '%q' "$agent")"
      if [[ -n "$model" ]]; then
        launch_cmd+=" --model $(printf '%q' "$model")"
        model=""
      fi
    fi
  fi
  local model_prefix=""
  if [[ -n "$model" ]]; then
    model_prefix="export ZCREW_MODEL=$(printf '%q' "$model"); "
  fi
  local pane_id
  local _stderr_file
  _stderr_file=$(mktemp)
  pane_id=$(mx_new_pane "$PROJECT_DIR" "$name" "$trap_cmd; ${model_prefix}$launch_cmd" 2>"$_stderr_file")
  local rc=$?
  logger "spawn" "info" "new-pane returned rc=$rc pane_id='$pane_id'"

  if [[ $rc -ne 0 ]]; then
    echo "zcrew: multiplexer new-pane failed: $(cat "$_stderr_file")" >&2
    rm -f "$_stderr_file"
    exit 1
  fi
  rm -f "$_stderr_file"

  local now
  now=$(date +%s)
  registry_write_jq '
    .version = 1
    | .panes = (.panes // {})
    | .panes[$name] = {
        paneId: $paneId,
        sessionId: null,
        agent: $agent,
        projectDir: $projectDir,
        cwd: $cwd,
        pid: null,
        lastSeen: ($now | tonumber),
        status: "alive"
      }
  ' \
    --arg name "$name" \
    --arg paneId "$pane_id" \
    --arg agent "$agent" \
    --arg projectDir "$PROJECT_DIR" \
    --arg cwd "$PROJECT_DIR" \
    --arg now "$now"

  echo "spawned: $name ($agent) pane=$pane_id"
}

live_pane_ids() {
  mx_list_pane_ids "$@"
}

# ── codex worker state cleanup ──────────────────────────────────────────
# Codex workers run as 3-process trees inside bx (--unshare-pid). PIDs in
# the inner pid files are namespace-relative and useless from outside; the
# outer launcher writes its own host-visible PID to outer.pid before
# exec-ing into bx so external cleanup can kill bwrap → kernel SIGKILLs
# everything inside.

read_pid_file() {
  local pid_file="$1"
  [[ -f "$pid_file" ]] || return 1
  local pid
  pid="$(tr -dc '0-9' < "$pid_file" || true)"
  [[ -n "$pid" ]] || return 1
  printf '%s\n' "$pid"
}

read_starttime_file() {
  local starttime_file="$1"
  [[ -f "$starttime_file" ]] || return 1
  local starttime
  starttime="$(tr -dc '0-9' < "$starttime_file" || true)"
  [[ -n "$starttime" ]] || return 1
  printf '%s\n' "$starttime"
}

parse_proc_stat_starttime() {
  local raw="${1:-}"
  [[ -n "$raw" ]] || return 1
  local tail="${raw##*) }"
  awk -v t="$tail" 'BEGIN{n=split(t,a," "); if (n < 20) exit 1; print a[20]}'
}

read_proc_starttime() {
  local pid="$1"
  local raw
  raw="$(cat "/proc/$pid/stat" 2>/dev/null)" || return 1
  parse_proc_stat_starttime "$raw"
}

kill_outer_pid_if_safe() {
  local pane_id="$1"
  local outer_pid_file="$PROJECT_DIR/.zcrew/state/codex-worker/$pane_id/outer.pid"
  local outer_starttime_file="$PROJECT_DIR/.zcrew/state/codex-worker/$pane_id/outer.starttime"
  local pid recorded_starttime current_starttime
  pid="$(read_pid_file "$outer_pid_file" || true)"
  [[ -n "$pid" ]] || return 0
  recorded_starttime="$(read_starttime_file "$outer_starttime_file" || true)"
  [[ -n "$recorded_starttime" ]] || return 0
  if ! kill -0 "$pid" 2>/dev/null; then
    return 0
  fi
  current_starttime="$(read_proc_starttime "$pid" || true)"
  if [[ -z "$current_starttime" || "$current_starttime" != "$recorded_starttime" ]]; then
    logger "gc" "warn" "skip kill for mismatched outer pid identity paneId=$pane_id pid=$pid"
    return 0
  fi
  kill "$pid" 2>/dev/null || true
  local deadline=$((SECONDS + 3))
  while kill -0 "$pid" 2>/dev/null; do
    if (( SECONDS >= deadline )); then
      kill -9 "$pid" 2>/dev/null || true
      break
    fi
    sleep 0.1
  done
}

walk_codex_worker_orphans() {
  local mode="${1:-safe}"
  local now
  now=$(date +%s)
  local live_json='[]'
  if [[ "$mode" != "force" ]]; then
    local live_lines
    live_lines="$(live_pane_ids 2>/dev/null || true)"
    live_json=$(printf '%s\n' "$live_lines" | jq -Rsc 'split("\n") | map(select(length>0))')
    if [[ "$live_json" == "[]" ]]; then
      logger "gc" "warn" "skip orphan walk: empty live pane list"
      return 0
    fi
  fi
  local root="$PROJECT_DIR/.zcrew/state/codex-worker"
  [[ -d "$root" ]] || return 0
  local pane_path pane_id mtime age
  shopt -s nullglob
  for pane_path in "$root"/*; do
    [[ -d "$pane_path" ]] || continue
    pane_id="$(basename "$pane_path")"
    if [[ "$mode" != "force" ]]; then
      if jq -e --arg id "$pane_id" 'index($id) != null' <<< "$live_json" >/dev/null; then
        continue
      fi
    else
      mtime=$(stat -c %Y "$pane_path" 2>/dev/null || echo 0)
      age=$((now - mtime))
      if (( age < 30 )); then
        logger "gc" "info" "skip fresh state dir paneId=$pane_id age=${age}s"
        continue
      fi
    fi
    kill_outer_pid_if_safe "$pane_id"
    rm -rf "$pane_path"
    logger "gc" "info" "cleaned orphan codex worker state paneId=$pane_id mode=$mode"
  done
  shopt -u nullglob
}

cmd_unregister() {
  CURRENT_SUBCMD="unregister"
  require_project
  local name="${1:-}"
  [[ -n "$name" ]] || { echo "Usage: zcrew unregister <name>" >&2; exit 1; }
  logger "unregister" "info" "entry name=$name"
  registry_write_jq '
    .panes |= del(.[$name])
  ' --arg name "$name"
}

seed_mcp_configs() {
  local target="$1"
  local target_abs
  target_abs="$(realpath "$target")"
  local lib_dir
  lib_dir="$(resolve_lib_dir "$target_abs")"
  local server_path="$lib_dir/mcp_server.py"
  [[ -f "$server_path" ]] || {
    echo "zcrew install: lib not found at $server_path. This indicates a broken install." >&2
    echo "Run .zcrew/bin/zcrew install <target> from your zcrew clone to repair." >&2
    return 1
  }

  # Project-root .mcp.json for Claude Code (host orchestrator).
  local proj_mcp="$target/.mcp.json"
  local tmp
  tmp=$(mktemp "$proj_mcp.tmp.XXXXXX")
  if [[ -f "$proj_mcp" ]]; then
    if ! jq --arg cmd python3 --arg path "$server_path" \
        '.mcpServers = ((.mcpServers // {}) | .zcrew = {command:$cmd, args:[$path]})' \
        "$proj_mcp" > "$tmp" 2>/dev/null; then
      rm -f "$tmp"
      echo "warning: $proj_mcp is invalid JSON; not seeding zcrew MCP entry" >&2
    else
      mv "$tmp" "$proj_mcp"
    fi
  else
    jq -n --arg cmd python3 --arg path "$server_path" \
      '{mcpServers:{zcrew:{command:$cmd, args:[$path]}}}' > "$tmp"
    mv "$tmp" "$proj_mcp"
  fi

  # Sandbox pi mcp.json: pi worker uses the native extension (.zcrew/lib/
  # pi-zcrew-ext.ts), not MCP. Strip any pre-existing zcrew entry to avoid
  # double-fire. Preserve any non-zcrew entries the user may have added.
  local pi_mcp="$target/.bx/home/.pi/agent/mcp.json"
  if [[ -f "$pi_mcp" ]] && jq -e '.mcpServers.zcrew' "$pi_mcp" >/dev/null 2>&1; then
    tmp=$(mktemp "$pi_mcp.tmp.XXXXXX")
    jq '.mcpServers = ((.mcpServers // {}) | del(.zcrew))' "$pi_mcp" > "$tmp" \
      && mv "$tmp" "$pi_mcp" || rm -f "$tmp"
  fi

  # WORKER sandbox codex config.toml: codex workers use the app-server
  # adapter (.zcrew/lib/codex-auto-reply.mjs), not MCP. Strip any
  # pre-existing [mcp_servers.zcrew] block to avoid double-fire.
  # Preserve other tables.  (The ORCHESTRATOR seed is in
  # seed_orchestrator_configs below.)
  local codex_conf="$target/.bx/home/.codex/config.toml"
  if [[ -f "$codex_conf" ]] && grep -Fxq '[mcp_servers.zcrew]' "$codex_conf"; then
    tmp=$(mktemp "$codex_conf.tmp.XXXXXX")
    awk '
      BEGIN { skip = 0 }
      /^\[mcp_servers\.zcrew\][[:space:]]*$/ { skip = 1; next }
      skip && /^\[/ { skip = 0 }
      !skip { print }
    ' "$codex_conf" > "$tmp" && mv "$tmp" "$codex_conf" || rm -f "$tmp"
  fi
}

# Seed orchestrator-side configs so the user's own codex/pi pick up
# zcrew_send + zcrew_list automatically from the installed project.
seed_orchestrator_configs() {
  local target="$1"
  local target_abs
  target_abs="$(realpath "$target")"
  local lib_dir
  lib_dir="$(resolve_lib_dir "$target_abs")"
  local server_path="$lib_dir/mcp_server.py"
  [[ -f "$server_path" ]] || {
    echo "zcrew install: lib not found at $server_path. This indicates a broken install." >&2
    echo "Run .zcrew/bin/zcrew install <target> from your zcrew clone to repair." >&2
    return 1
  }

  # --- codex: merge [mcp_servers.zcrew] into <target>/.codex/config.toml ---
  # Idempotent: if the block already exists with the correct args, skip.
  # Preserves any other [mcp_servers.*] or unrelated keys.
  local codex_dir="$target/.codex"
  local codex_toml="$codex_dir/config.toml"
  mkdir -p "$codex_dir"

  if [[ -f "$codex_toml" ]] && grep -Fxq '[mcp_servers.zcrew]' "$codex_toml"; then
    # Block exists — rewrite args to current path (idempotent update).
    local tmp
    tmp=$(mktemp "$codex_toml.tmp.XXXXXX")
    awk -v server_path="$server_path" '
      BEGIN { in_zcrew = 0; did_args = 0 }
      /^\[mcp_servers\.zcrew\][[:space:]]*$/ { in_zcrew = 1; print; next }
      in_zcrew && /^\[/ { in_zcrew = 0 }
      in_zcrew && /^command[[:space:]]*=/ { print "command = \"python3\""; next }
      in_zcrew && /^args[[:space:]]*=/ { print "args = [\"" server_path "\"]"; did_args = 1; next }
      !in_zcrew { print }
    ' "$codex_toml" > "$tmp" && mv "$tmp" "$codex_toml" || rm -f "$tmp"
  else
    # No existing block — append.
    cat >> "$codex_toml" <<EOF

[mcp_servers.zcrew]
command = "python3"
args = ["$server_path"]
EOF
  fi
  echo "    .codex/config.toml (orchestrator zcrew MCP entry)"

  # --- pi: symlink <target>/.pi/extensions/zcrew.ts -> <resolved-lib>/pi-zcrew-ext.ts ---
  local pi_ext_dir="$target/.pi/extensions"
  local pi_ext_link="$pi_ext_dir/zcrew.ts"
  local expected_target='../../.zcrew/lib/pi-zcrew-ext.ts'

  mkdir -p "$pi_ext_dir"
  if [[ -L "$pi_ext_link" ]]; then
    if [[ "$(readlink "$pi_ext_link")" == "$expected_target" ]]; then
      : # already correct
    else
      rm -f "$pi_ext_link"
      ln -s "$expected_target" "$pi_ext_link"
    fi
  elif [[ -e "$pi_ext_link" ]]; then
    # Existing real file — replace with symlink.
    rm -f "$pi_ext_link"
    ln -s "$expected_target" "$pi_ext_link"
  else
    ln -s "$expected_target" "$pi_ext_link"
  fi
  echo "    .pi/extensions/zcrew.ts -> $expected_target"
}

install_bootstrap() {
  local target="$1"
  local bx_bin="$2"
  local zcrew_bin="$3"

  # Defensive cleanup: remove stray empty local mountpoint dirs left by bwrap.
  if [[ -d "$target/.zcrew/bin" ]] && [[ -z "$(find "$target/.zcrew/bin" -mindepth 1 -print -quit 2>/dev/null)" ]]; then
    rmdir "$target/.zcrew/bin" 2>/dev/null || true
  fi
  if [[ -d "$target/.zcrew/lib" ]] && [[ -z "$(find "$target/.zcrew/lib" -mindepth 1 -print -quit 2>/dev/null)" ]]; then
    rmdir "$target/.zcrew/lib" 2>/dev/null || true
  fi

  write_managed_mise_floor "$target"
  echo "    .config/mise.toml (zcrew managed floor)"
  if command -v mise >/dev/null 2>&1; then
    mise trust "$target/.config/mise.toml" >/dev/null 2>&1 || true
    echo "    .config/mise.toml (trusted)"
  fi
  (
    cd "$target"
    env -u BX_INSIDE "$bx_bin" init >/dev/null
  )
  echo "    .bx/ (bx init — idempotent)"
  (
    cd "$target"
    bash "$zcrew_bin" init >/dev/null
  )
  echo "    .zcrew/ (zcrew init — idempotent)"
  if [[ -d "$target/.bx" ]]; then
    ensure_gitignore_lines "$target/.bx/.gitignore" \
      "home/" \
      ".provisioned"
    echo "    .bx/.gitignore (ensured managed entries)"
    write_managed_sandbox_gitignore "$target"
    echo "    .bx/home/.config/git/ignore (zcrew managed)"
    if ensure_bx_managed_mounts "$target"; then
      echo "    .bx/mounts (rewrote managed block)"
    fi
  fi
  if [[ -d "$target/.zcrew" ]]; then
    ensure_team_conf_template "$target"
    echo "    .zcrew/team.conf (seeded if missing)"
    ensure_gitignore_lines "$target/.zcrew/.gitignore" \
      "registry.json" \
      "registry.lock" \
      "audit.log" \
      "spawn/"
    echo "    .zcrew/.gitignore (ensured managed entries)"
    if [[ -d "$target/.zcrew/lib" ]]; then
      seed_mcp_configs "$target"
      echo "    .mcp.json + sandbox MCP configs (zcrew server entry)"
      seed_orchestrator_configs "$target"
    fi
  fi
}

# Install zcrew into a target project directory.
# Copies .zcrew-owned bin/lib content plus skills and managed config.
verify_managed_copy() {
  local src_dir="$1"
  local dst_dir="$2"
  local src_abs dst_abs rel mismatched=0
  src_abs="$(realpath "$src_dir")"
  dst_abs="$(realpath "$dst_dir")"

  local display_prefix="${PROJECT_DIR:-$PWD}"

  while IFS= read -r -d '' src_path; do
    rel="${src_path#$src_abs/}"
    if [[ ! -f "$dst_abs/$rel" ]] || ! cmp -s "$src_path" "$dst_abs/$rel"; then
      echo "warning: managed skill path was overwritten after install: ${dst_dir#$display_prefix/}/$rel" >&2
      mismatched=1
    fi
  done < <(find -L "$src_abs" -type f -print0)

  if [[ "$mismatched" == "1" ]]; then
    echo "warning: some managed skill files do not match installed source content; investigate target post-install tooling" >&2
    return 1
  fi
  return 0
}

count_line_diff() {
  local left="$1"
  local right="$2"
  local left_lines right_lines diff
  left_lines="$(wc -l < "$left" 2>/dev/null || printf '0\n')"
  right_lines="$(wc -l < "$right" 2>/dev/null || printf '0\n')"
  diff=$((left_lines - right_lines))
  if (( diff < 0 )); then
    diff=$(( -diff ))
  fi
  printf '%s\n' "$diff"
}

classify_managed_file() {
  local target_path="$1"
  local src_path="$2"
  local rel="${3:-}"
  local require_owned="${4:-0}"

  if [[ ! -e "$target_path" && ! -L "$target_path" ]]; then
    printf 'absent\t-\n'
    return 0
  fi
  if cmp -s "$src_path" "$target_path" 2>/dev/null; then
    printf 'managed-pristine\t-\n'
    return 0
  fi
  if [[ "$require_owned" == "1" ]] && ! is_zcrew_owned_file "$target_path" "$rel"; then
    printf 'user-file\t-\n'
    return 0
  fi
  printf 'managed-modified\t%s\n' "$(count_line_diff "$src_path" "$target_path")"
}

print_install_plan_tree() {
  local src_dir="$1"
  local dst_dir="$2"
  local require_owned="${3:-0}"
  local src_path rel dst_path state meta

  while IFS= read -r -d '' src_path; do
    rel="${src_path#$src_dir/}"
    dst_path="$dst_dir/$rel"
    IFS=$'\t' read -r state meta < <(classify_managed_file "$dst_path" "$src_path" "${dst_path#"$target_abs"/}" "$require_owned")
    case "$state" in
      absent)
        PLAN_REPLACE+=("${dst_path#"$target_abs"/} (create)")
        ;;
      managed-pristine)
        PLAN_REPLACE+=("${dst_path#"$target_abs"/} (overwrite, managed-pristine)")
        ;;
      managed-modified)
        PLAN_REPLACE+=("${dst_path#"$target_abs"/} (overwrite, managed-modified, line-diff=$meta)")
        ;;
    esac
  done < <(find -L "$src_dir" -type f -print0 | sort -z)
}

print_plan_section() {
  local title="$1"
  shift
  local -a items=("$@")
  printf '%s\n' "$title"
  if [[ "${#items[@]}" -eq 0 ]]; then
    printf '  (none)\n'
    return 0
  fi
  local item
  for item in "${items[@]}"; do
    printf '  %s\n' "$item"
  done
}

print_install_plan() {
  local src="$1"
  local target="$2"
  local target_abs="$3"
  local -a PLAN_REPLACE=()
  local -a PLAN_KEEP=()
  local -a PLAN_SKIP=()
  local rel src_path dst_path state meta

  while IFS= read -r rel; do
    src_path="$src/.zcrew/bin/$rel"
    dst_path="$target_abs/.zcrew/bin/$rel"
    IFS=$'\t' read -r state meta < <(classify_managed_file "$dst_path" "$src_path" ".zcrew/bin/$rel" 0)
    case "$state" in
      absent) PLAN_REPLACE+=(".zcrew/bin/$rel (create)") ;;
      managed-pristine) PLAN_REPLACE+=(".zcrew/bin/$rel (overwrite, managed-pristine)") ;;
      managed-modified) PLAN_REPLACE+=(".zcrew/bin/$rel (overwrite, managed-modified, line-diff=$meta)") ;;
    esac
  done < <(zcrew_owned_bin_files)

  while IFS= read -r rel; do
    src_path="$src/.zcrew/lib/$rel"
    dst_path="$target_abs/.zcrew/lib/$rel"
    IFS=$'\t' read -r state meta < <(classify_managed_file "$dst_path" "$src_path" ".zcrew/lib/$rel" 0)
    case "$state" in
      absent) PLAN_REPLACE+=(".zcrew/lib/$rel (create)") ;;
      managed-pristine) PLAN_REPLACE+=(".zcrew/lib/$rel (overwrite, managed-pristine)") ;;
      managed-modified) PLAN_REPLACE+=(".zcrew/lib/$rel (overwrite, managed-modified, line-diff=$meta)") ;;
    esac
  done < <(zcrew_owned_lib_files)

  IFS=$'\t' read -r state meta < <(classify_managed_file "$target_abs/AGENTS.md" "$src/AGENTS.md" "AGENTS.md" 1)
  case "$state" in
    absent) PLAN_REPLACE+=("AGENTS.md (create)") ;;
    managed-pristine|managed-modified) PLAN_KEEP+=("AGENTS.md (will skip; install preserves existing file)") ;;
    user-file) PLAN_SKIP+=("AGENTS.md (user file; no zcrew ownership marker)") ;;
  esac

  if [[ "$state" != "absent" ]]; then
    PLAN_KEEP+=("CLAUDE.md (will skip; AGENTS.md already exists)")
  elif [[ -e "$target_abs/CLAUDE.md" || -L "$target_abs/CLAUDE.md" ]]; then
    PLAN_KEEP+=("CLAUDE.md (will skip; install preserves existing file)")
  else
    PLAN_REPLACE+=("CLAUDE.md (create symlink to AGENTS.md)")
  fi

  print_install_plan_tree "$src/.agents/skills/zcrew" "$target_abs/.agents/skills/zcrew" 0
  print_install_plan_tree "$src/.claude/skills" "$target_abs/.claude/skills" 0
  print_install_plan_tree "$src/.pi/skills" "$target_abs/.pi/skills" 0
  print_install_plan_tree "$src/.codex/skills/zcrew" "$target_abs/.codex/skills/zcrew" 0

  PLAN_KEEP+=(".bx/config (bx init idempotent)")
  PLAN_KEEP+=(".bx/mounts (will merge/rewrite zcrew-managed block)")
  PLAN_KEEP+=(".bx/.gitignore (will ensure managed entries)")
  PLAN_KEEP+=(".bx/home/ (preserve sandbox home and runtime state)")
  PLAN_KEEP+=(".bx/home/.config/git/ignore (will ensure managed entries)")
  PLAN_KEEP+=(".config/mise.toml (will rewrite zcrew managed floor)")
  PLAN_KEEP+=(".mcp.json (will merge/rewrite zcrew MCP entry)")
  PLAN_KEEP+=(".codex/config.toml (will merge/rewrite zcrew block)")
  PLAN_KEEP+=(".pi/extensions/zcrew.ts (will relink managed extension)")
  PLAN_KEEP+=(".zcrew/.gitignore (will ensure managed entries)")
  PLAN_KEEP+=(".zcrew/registry.json (preserve runtime state)")
  PLAN_KEEP+=(".zcrew/registry.lock (preserve runtime state)")
  PLAN_KEEP+=(".zcrew/audit.log (preserve runtime state)")
  PLAN_KEEP+=(".zcrew/spawn/ (preserve runtime state)")
  PLAN_KEEP+=(".zcrew/team.conf (preserve if present; seed if missing)")

  printf '==> dry-run install plan for %s\n' "$target_abs"
  print_plan_section "REPLACE" "${PLAN_REPLACE[@]}"
  print_plan_section "KEEP" "${PLAN_KEEP[@]}"
  print_plan_section "SKIP" "${PLAN_SKIP[@]}"
}

# Return 0 if no stale paths, 1 if any stale .zcrew/{bin,lib} paths found.
print_stale_paths() {
  local target_abs="$1"
  local zcrew_prefix="$target_abs/.zcrew"
  local found_stale=false
  local -a stale_entries=()

  is_stale_zcrew_path() {
    local path="$1"
    [[ "$path" == /* ]] || return 1
    [[ "$path" =~ ^.*/\.zcrew/(bin|lib)(/|$) ]] || return 1
    local prefix="${path%/.zcrew/*}/.zcrew"
    [[ "$prefix" != "$zcrew_prefix" ]]
  }

  # 1. .mcp.json
  if [[ -f "$target_abs/.mcp.json" ]]; then
    local mcp_path=""
    mcp_path="$(jq -r '.mcpServers.zcrew.args[0] // empty' "$target_abs/.mcp.json" 2>/dev/null || true)"
    if [[ -n "$mcp_path" ]] && is_stale_zcrew_path "$mcp_path"; then
      stale_entries+=("  .mcp.json")
      stale_entries+=("    mcpServers.zcrew.args[0] = $mcp_path")
      found_stale=true
    fi
  fi

  # 2. .codex/config.toml
  if [[ -f "$target_abs/.codex/config.toml" ]]; then
    local codex_path=""
    codex_path="$(awk '/^\[mcp_servers\.zcrew\]/ { in_block=1; next }
                       /^\[/ { in_block=0 }
                       in_block && /^args[[:space:]]*=/ {
                         match($0, /\[.*\]/);
                         path = substr($0, RSTART+1, RLENGTH-2);
                         gsub(/"/, "", path);
                         print path;
                       }' "$target_abs/.codex/config.toml" 2>/dev/null || true)"
    if [[ -n "$codex_path" ]] && is_stale_zcrew_path "$codex_path"; then
      stale_entries+=("  .codex/config.toml")
      stale_entries+=("    [mcp_servers.zcrew] args = $codex_path")
      found_stale=true
    fi
  fi

  # 3. .claude/settings.local.json
  if [[ -f "$target_abs/.claude/settings.local.json" ]]; then
    local -a hook_cmds=()
    while IFS= read -r cmd; do
      [[ -n "$cmd" ]] || continue
      if is_stale_zcrew_path "$cmd"; then
        hook_cmds+=("$cmd")
      fi
    done < <(jq -r '.hooks.Stop[]?.hooks[]? | select(.type == "command") | .command' "$target_abs/.claude/settings.local.json" 2>/dev/null || true)
    if [[ "${#hook_cmds[@]}" -gt 0 ]]; then
      stale_entries+=("  .claude/settings.local.json")
      local hcmd
      for hcmd in "${hook_cmds[@]}"; do
        stale_entries+=("    hooks.Stop[].hooks[].command = $hcmd")
      done
      found_stale=true
    fi
  fi

  # 4. .bx/mounts (managed block only)
  if [[ -f "$target_abs/.bx/mounts" ]]; then
    local -a mount_paths=()
    local in_managed=false line src_path
    while IFS= read -r line || [[ -n "$line" ]]; do
      if [[ "$line" == '# zcrew-managed begin' ]]; then
        in_managed=true
        continue
      fi
      if [[ "$line" == '# zcrew-managed end' ]]; then
        in_managed=false
        continue
      fi
      if [[ "$in_managed" == "true" && ! "$line" =~ ^# ]]; then
        src_path="${line%% *}"
        if is_stale_zcrew_path "$src_path"; then
          mount_paths+=("$src_path")
        fi
      fi
    done < "$target_abs/.bx/mounts"
    if [[ "${#mount_paths[@]}" -gt 0 ]]; then
      stale_entries+=("  .bx/mounts")
      local mp
      for mp in "${mount_paths[@]}"; do
        stale_entries+=("    managed mount source = $mp")
      done
      found_stale=true
    fi
  fi

  if [[ "$found_stale" == "true" ]]; then
    printf 'STALE PATHS DETECTED (re-run `zcrew install .` to fix):\n'
    local entry
    for entry in "${stale_entries[@]}"; do
      printf '%s\n' "$entry"
    done
    return 1
  fi

  return 0
}

cmd_install() {
  CURRENT_SUBCMD="install"
  local target=""
  local keep_compat=false
  local dry_run=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keep) keep_compat=true ;;
      --dry-run) dry_run=true ;;
      --*) echo "Usage: zcrew install [--keep] [--dry-run] <target-project-dir>" >&2; exit 1 ;;
      *)
        if [[ -n "$target" ]]; then
          echo "Usage: zcrew install [--keep] [--dry-run] <target-project-dir>" >&2
          exit 1
        fi
        target="$1"
        ;;
    esac
    shift
  done
  [[ -n "$target" ]] || { echo "Usage: zcrew install [--keep] [--dry-run] <target-project-dir>" >&2; exit 1; }
  [[ -d "$target" ]] || { echo "zcrew: target dir does not exist: $target" >&2; exit 1; }
  local target_abs
  target_abs=$(realpath "$target")

  local source_info self src
  source_info="$(detect_install_source)"
  IFS='|' read -r _self self src <<< "$source_info"
  local bx_bootstrap_bin zcrew_bootstrap_bin
  zcrew_bootstrap_bin="$self"
  bx_bootstrap_bin="$src/.zcrew/bin/bx"
  [[ -f "$src/.zcrew/bin/zcrew" ]] || { echo "zcrew: source repo not found at $src" >&2; exit 1; }
  [[ -f "$src/.zcrew/bin/bx" ]] || { echo "zcrew: source bx missing at $src/.zcrew/bin/bx" >&2; exit 1; }
  [[ -f "$src/.zcrew/bin/ix" ]] || { echo "zcrew: source ix missing at $src/.zcrew/bin/ix" >&2; exit 1; }
  [[ -f "$src/.zcrew/lib/tell" ]] || { echo "zcrew: source tell missing at $src/.zcrew/lib/tell" >&2; exit 1; }
  [[ -f "$src/.zcrew/lib/multiplexer.sh" ]] || { echo "zcrew: source multiplexer missing at $src/.zcrew/lib/multiplexer.sh" >&2; exit 1; }
  [[ -f "$src/.zcrew/lib/launchers/claude.sh" ]] || { echo "zcrew: source launcher missing at $src/.zcrew/lib/launchers/claude.sh" >&2; exit 1; }
  [[ -f "$src/.zcrew/lib/launchers/codex.sh" ]] || { echo "zcrew: source launcher missing at $src/.zcrew/lib/launchers/codex.sh" >&2; exit 1; }
  [[ -f "$src/.zcrew/lib/launchers/pi.sh" ]] || { echo "zcrew: source launcher missing at $src/.zcrew/lib/launchers/pi.sh" >&2; exit 1; }
  [[ -d "$src/.agents/skills/zcrew" ]] || { echo "zcrew: source skill dir missing at $src/.agents/skills/zcrew" >&2; exit 1; }
  [[ -d "$src/.claude/skills" ]] || { echo "zcrew: source skills dir missing at $src/.claude/skills" >&2; exit 1; }
  [[ -d "$src/.pi/skills" ]] || { echo "zcrew: source skills dir missing at $src/.pi/skills" >&2; exit 1; }
  [[ -d "$src/.codex/skills/zcrew" ]] || { echo "zcrew: source skill dir missing at $src/.codex/skills/zcrew" >&2; exit 1; }
  [[ -f "$src/AGENTS.md" ]] || { echo "zcrew: source AGENTS.md missing at $src/AGENTS.md" >&2; exit 1; }

  local src_abs migrated stale
  src_abs=$(realpath "$src")
  if [[ "$dry_run" == "true" ]]; then
    print_install_plan "$src" "$target" "$target_abs"
    print_stale_paths "$target_abs"
    return
  fi
  if [[ "$src_abs" == "$target_abs" ]]; then
    echo "==> source == target ($target_abs); skipping materialization, running bootstrap only"
    install_bootstrap "$target" "$bx_bootstrap_bin" "$zcrew_bootstrap_bin"
    return 0
  fi

  migrated=false
  [[ -x "$target/.zcrew/bin/zcrew" ]] && migrated=true

  echo "==> installing zcrew from $src into $target"
  copy_managed_layout "$src" "$target"
  if ! verify_managed_layout "$target"; then
    copy_managed_layout "$src" "$target"
  fi
  verify_managed_layout "$target" || { echo "zcrew: failed to materialize managed .zcrew/bin and .zcrew/lib layout" >&2; exit 1; }
  echo "    .zcrew/bin/{zcrew,bx,ix}"
  echo "    .zcrew/lib/{tell,launchers/*}"

  # Canonical cross-tool skill first; copy with -L so source symlinks become real content in-target.
  mkdir -p "$target/.agents/skills"
  rm -rf "$target/.agents/skills/zcrew"
  cp -rL "$src/.agents/skills/zcrew" "$target/.agents/skills/"
  verify_managed_copy "$src/.agents/skills/zcrew" "$target/.agents/skills/zcrew" || true
  echo "    .agents/skills/zcrew"

  mkdir -p "$target/.claude/skills"
  for skill in zspawn zsend zpanes zsync zname zclose zcrew; do
    rm -rf "$target/.claude/skills/$skill"
    cp -rL "$src/.claude/skills/$skill" "$target/.claude/skills/"
    verify_managed_copy "$src/.claude/skills/$skill" "$target/.claude/skills/$skill" || true
    echo "    .claude/skills/$skill"
  done
  mkdir -p "$target/.pi/skills"
  for skill in zspawn zsend zpanes zsync zname zclose zcrew; do
    rm -rf "$target/.pi/skills/$skill"
    cp -rL "$src/.pi/skills/$skill" "$target/.pi/skills/"
    verify_managed_copy "$src/.pi/skills/$skill" "$target/.pi/skills/$skill" || true
    echo "    .pi/skills/$skill"
  done
  mkdir -p "$target/.codex/skills"
  rm -rf "$target/.codex/skills/zcrew"
  cp -rL "$src/.codex/skills/zcrew" "$target/.codex/skills/"
  verify_managed_copy "$src/.codex/skills/zcrew" "$target/.codex/skills/zcrew" || true
  echo "    .codex/skills/zcrew"

  if [[ -f "$target/AGENTS.md" ]]; then
    echo "    AGENTS.md / CLAUDE.md (skipped: target already has AGENTS.md)"
  elif [[ -e "$target/CLAUDE.md" ]]; then
    cp "$src/AGENTS.md" "$target/AGENTS.md"
    echo "    AGENTS.md"
    echo "    CLAUDE.md (skipped: target already has CLAUDE.md)"
  else
    cp "$src/AGENTS.md" "$target/AGENTS.md"
    echo "    AGENTS.md"
    ln -s AGENTS.md "$target/CLAUDE.md"
    echo "    CLAUDE.md -> AGENTS.md"
  fi

  local settings_before settings_after
  settings_before=""
  if [[ -f "$target/.claude/settings.json" ]]; then
    settings_before=$(cat "$target/.claude/settings.json")
  fi
  if remove_zcrew_sessionstart_hook "$target"; then
    if jq -e 'type == "object" and length == 0' "$target/.claude/settings.json" >/dev/null 2>&1; then
      rm -f "$target/.claude/settings.json"
      settings_after=""
    else
      settings_after=$(cat "$target/.claude/settings.json")
    fi
  else
    settings_after="$settings_before"
  fi
  if [[ "$settings_before" != "$settings_after" ]]; then
    echo "    .claude/settings.json (removed retired SessionStart hook)"
  fi
  rm -f "$target/.claude/hooks/zcrew-register.sh"
  rmdir --ignore-fail-on-non-empty "$target/.claude/hooks" 2>/dev/null || true

  if [[ "$keep_compat" == "true" ]]; then
    create_keep_symlinks "$target"
    echo "    bin/zcrew etc. are now symlinks (transitional); add to .gitignore yourself if desired"
  fi

  install_bootstrap "$target" "$bx_bootstrap_bin" "$zcrew_bootstrap_bin"

  echo ""
  echo "==> zcrew installed in $target_abs"
  echo ""
  echo "Next steps:"
  echo "  1. cd $target_abs"
  echo "  2. Restart claude in this dir to load the new skills."
  echo "  3. codex orchestrator: first run will trust-prompt; accept once."
}

cmd_rename() {
  CURRENT_SUBCMD="rename"
  require_project
  local old="${1:-}"
  local new="${2:-}"
  [[ -n "$old" && -n "$new" ]] || { echo "Usage: zcrew rename <old> <new>" >&2; exit 1; }
  logger "rename" "info" "entry old=$old new=$new"
  if [[ "$old" == "main" ]]; then
    echo "zcrew: cannot rename main alias" >&2
    exit 1
  fi
  if [[ "$new" == "main" ]] && jq -e '(.panes // {}).main != null' "$REGISTRY_FILE" >/dev/null; then
    echo "zcrew: main alias is taken" >&2
    exit 1
  fi
  local pane_id
  pane_id=$(jq -r --arg old "$old" '(.panes // {}) | .[$old].paneId // empty' "$REGISTRY_FILE")
  registry_write_jq '
    .version = 1
    | .panes = (.panes // {})
    | if (.panes[$old] == null) then
        error("zcrew: name '\''" + $old + "'\'' does not exist")
      elif (.panes[$new] != null) then
        error("zcrew: name '\''" + $new + "'\'' already exists")
      else
        (.panes[$old].paneId // "") as $paneId
        | .panes[$new] = .panes[$old]
        | .panes |= del(.[$old])
        | .panes |= del(.["pane-" + $paneId])
      end
  ' \
    --arg old "$old" \
    --arg new "$new"
  # Best-effort: rename the live pane title when a multiplexer session exists.
  if [[ -n "$pane_id" ]]; then
    mx_rename_pane "$pane_id" "$new" >/dev/null 2>&1 || true
  fi
  echo "renamed: $old -> $new"
}

resolve_sender_name_readonly() {
  require_project
  ensure_registry_files

  local pane_id=""
  pane_id="$( (_MX_BACKEND_CHECKED=1 mx_pane_id) 2>/dev/null || echo)"
  [[ -n "$pane_id" ]] || pane_id="0"

  jq -r --arg paneId "$pane_id" '
    (.panes // {})
    | to_entries
    | map(select((.value.paneId // "") == $paneId))
    | sort_by(if (.key | test("^pane-[0-9]+$")) then 1 else 0 end)
    | .[0].key // empty
  ' "$REGISTRY_FILE"
}

lookup_live_main_info() {
  require_project
  ensure_registry_files

  local live_json
  live_json=$(live_pane_ids | jq -Rsc 'split("\n") | map(select(length>0))')

  jq -r --argjson live "$live_json" '
    (.panes.main // null) as $main
    | if $main == null then
        empty
      elif ($live | index($main.paneId // "")) == null then
        empty
      else
        "main\t" + ($main.paneId // "")
      end
  ' "$REGISTRY_FILE"
}

claim_main_alias() {
  local force_replace="${1:-false}"
  require_project
  ensure_registry_files

  local pane_id=""
  pane_id="$(mx_pane_id 2>/dev/null || true)"
  [[ -n "$pane_id" ]] || pane_id="0"

  local now live_json
  now=$(date +%s)
  live_json=$(live_pane_ids | jq -Rsc 'split("\n") | map(select(length>0))')

  registry_write_jq '
    .version = 1
    | .panes = (.panes // {})
    | if ($force == "true") or (((.panes.main.paneId // "") as $mainPaneId | ($live | index($mainPaneId)) == null)) then
        ((.panes
          | to_entries
          | map(select((.value.paneId // "") == $paneId))
          | sort_by(if (.key | test("^pane-[0-9]+$")) then 1 else 0 end)
          | .[0].value) // {
            paneId: $paneId,
            sessionId: null,
            agent: "unknown",
            projectDir: $projectDir,
            cwd: $cwd,
            pid: ($pid | tonumber),
            lastSeen: ($now | tonumber),
            status: "alive"
          }) as $entry
        | .panes |= del(.["pane-" + $paneId])
        | .panes.main = ($entry
            | .paneId = $paneId
            | .projectDir = (.projectDir // $projectDir)
            | .cwd = (.cwd // $cwd)
            | .pid = (.pid // ($pid | tonumber))
            | .lastSeen = ($now | tonumber)
            | .status = "alive")
      else
        .
      end
  ' \
    --arg force "$force_replace" \
    --arg paneId "$pane_id" \
    --arg projectDir "$PROJECT_DIR" \
    --arg cwd "$PWD" \
    --arg pid "$$" \
    --arg now "$now" \
    --argjson live "$live_json"
}

claim_main_for_send() {
  require_project
  ensure_registry_files

  if [[ -n "${BX_INSIDE:-}" ]]; then
    resolve_sender_name_readonly
    return 0
  fi

  local pane_id=""
  pane_id="$(mx_pane_id 2>/dev/null || true)"
  [[ -n "$pane_id" ]] || return 0

  claim_main_alias false
}

lookup_registered_pane_id() {
  local name="${1:-}"
  jq -r --arg name "$name" '.panes[$name].paneId // empty' "$REGISTRY_FILE"
}

lookup_registered_agent() {
  local name="${1:-}"
  jq -r --arg name "$name" '.panes[$name].agent // empty' "$REGISTRY_FILE"
}

lookup_registered_cwd() {
  local name="${1:-}"
  jq -r --arg name "$name" '.panes[$name].cwd // empty' "$REGISTRY_FILE"
}

lookup_registered_project_dir() {
  local name="${1:-}"
  jq -r --arg name "$name" '.panes[$name].projectDir // empty' "$REGISTRY_FILE"
}

lookup_registered_status() {
  local name="${1:-}"
  jq -r --arg name "$name" '.panes[$name].status // empty' "$REGISTRY_FILE"
}

backfill_registered_project_dir() {
  local name="${1:-}"
  local project_dir="${2:-}"
  [[ -n "$name" && -n "$project_dir" ]] || return 1
  registry_write_jq '
    if .panes[$name] == null then
      .
    else
      .panes[$name].projectDir = $projectDir
    end
  ' \
    --arg name "$name" \
    --arg projectDir "$project_dir"
}

write_claude_target_state() {
  local dst_home="$1"
  local target_cwd="$2"

  mkdir -p "$dst_home/.claude" 2>/dev/null || return 1

  local tmp_settings="$dst_home/.claude/settings.json.tmp.$$"
  printf '{"skipDangerousModePermissionPrompt":true}\n' > "$tmp_settings" || return 1
  chmod 600 "$tmp_settings" 2>/dev/null || true
  mv "$tmp_settings" "$dst_home/.claude/settings.json" 2>/dev/null || return 1

  local tmp_json="$dst_home/.claude.json.tmp.$$"
  if ! jq -cn --arg workdir "$target_cwd" '{hasCompletedOnboarding:true,projects:{($workdir):{hasTrustDialogAccepted:true}}}' > "$tmp_json"; then
    rm -f "$tmp_json"
    return 1
  fi
  chmod 600 "$tmp_json" 2>/dev/null || true
  mv "$tmp_json" "$dst_home/.claude.json" 2>/dev/null || {
    rm -f "$tmp_json"
    return 1
  }
}

refresh_claude_auth_for_target() {
  local target_cwd="${1:-}"
  local target_agent="${2:-}"
  [[ "$target_agent" == "claude" ]] || return 0
  [[ -n "$target_cwd" ]] || return 0

  local dst_home="$target_cwd/.bx/home"
  [[ -d "$dst_home" ]] || return 0

  local host_home="${HOME:-}"
  if [[ -z "$host_home" ]]; then
    host_home="$(getent passwd "$(id -u)" 2>/dev/null | cut -d: -f6)"
  fi
  [[ -n "$host_home" ]] || return 0

  local src_creds="$host_home/.claude/.credentials.json"
  [[ -f "$src_creds" ]] || { logger "send" "warn" "no host .credentials.json to sync"; return 0; }

  if ! write_claude_target_state "$dst_home" "$target_cwd"; then
    logger "send" "warn" "write sandbox claude state failed"
    return 0
  fi

  local tmp_creds="$dst_home/.claude/.credentials.json.tmp.$$"
  if ! cp "$src_creds" "$tmp_creds" 2>/dev/null; then
    rm -f "$tmp_creds"
    logger "send" "warn" "copy .credentials.json failed"
    return 0
  fi
  if ! chmod 600 "$tmp_creds" 2>/dev/null; then
    rm -f "$tmp_creds"
    logger "send" "warn" "chmod .credentials.json failed"
    return 0
  fi
  if ! mv "$tmp_creds" "$dst_home/.claude/.credentials.json" 2>/dev/null; then
    rm -f "$tmp_creds"
    logger "send" "warn" "move .credentials.json failed"
    return 0
  fi

  logger "send" "info" "refreshed claude auth in $dst_home"
}

live_registered_panes() {
  local live_json
  live_json=$(live_pane_ids | jq -Rsc 'split("\n") | map(select(length>0))')
  jq -r --argjson live "$live_json" '
    (.panes // {})
    | to_entries
    | map(select((.value.paneId // "") as $id | ($live | index($id)) != null))
    | sort_by(.value.paneId, if (.key | test("^pane-[0-9]+$")) then 1 else 0 end, .key)
    | group_by(.value.paneId)
    | map(.[0] | "\(.key)\t\(.value.agent // "unknown")\t\(.value.paneId // "")")
    | .[]
  ' "$REGISTRY_FILE"
}

print_stale_send_error() {
  local name="$1"
  local stale_pane_id="$2"
  local stale_agent="${3:-claude}"

  echo "zcrew: pane '$name' is gone (paneId=$stale_pane_id not live)." >&2

  local live_lines
  live_lines=$(live_registered_panes)
  if [[ -z "$live_lines" ]]; then
    echo "Live panes: (none)" >&2
    echo "  zcrew spawn $stale_agent $name     # start fresh" >&2
    return
  fi

  echo "Live panes:" >&2
  local line live_name live_agent live_pane_id
  while IFS=$'\t' read -r live_name live_agent live_pane_id; do
    [[ -n "$live_name" ]] || continue
    echo "  $live_name ($live_agent)" >&2
  done <<< "$live_lines"
  while IFS=$'\t' read -r live_name live_agent live_pane_id; do
    [[ -n "$live_name" ]] || continue
    echo "  zcrew rename $live_name $name   # reassign existing live pane" >&2
  done <<< "$live_lines"
  echo "  zcrew spawn $stale_agent $name     # start fresh" >&2
}

cmd_close() {
  CURRENT_SUBCMD="close"
  require_project
  local name="${1:-}"
  [[ -n "$name" ]] || { echo "Usage: zcrew close <name>" >&2; exit 1; }
  logger "close" "info" "entry name=$name"

  local force=false
  if [[ "$name" == "--force" || "$name" == "--self" ]]; then
    force=true
    name="${1:-}"
    shift || true
    [[ -n "$name" ]] || { echo "Usage: zcrew close [--force] <name>" >&2; exit 1; }
  fi

  local pane_id
  pane_id=$(lookup_registered_pane_id "$name")
  if [[ -z "$pane_id" ]]; then
    logger "close" "error" "unknown name=$name"
    echo "zcrew: unknown pane name '$name'" >&2
    exit 1
  fi

  if [[ "$force" != "true" && "$pane_id" == "$(mx_pane_id)" ]]; then
    echo "zcrew: refusing to close yourself ($name, pane=$pane_id) — use: zcrew close --force $name" >&2
    exit 1
  fi

  local close_err=""
  if ! close_err=$(mx_close_pane "$pane_id" 2>&1); then
    logger "close" "warn" "close-pane failed name=$name paneId=$pane_id err='$close_err'"
    [[ -n "$close_err" ]] && echo "$close_err" >&2
  fi

  # Codex worker bookkeeping: kill bwrap (host-visible outer.pid) and
  # remove the per-pane state dir. No-op for non-codex panes (state dir
  # only exists for codex workers).
  local codex_state_dir="$PROJECT_DIR/.zcrew/state/codex-worker/$pane_id"
  if [[ -d "$codex_state_dir" ]]; then
    kill_outer_pid_if_safe "$pane_id"
    rm -rf "$codex_state_dir"
  fi

  "$0" unregister "$name"
  logger "close" "info" "closed name=$name paneId=$pane_id"
  echo "closed: $name ($pane_id)"
}

cmd_send() {
  CURRENT_SUBCMD="send"
  require_project
  local do_compact=false
  if [[ "${1:-}" == "--compact" ]]; then
    do_compact=true
    shift
  fi
  local name="${1:-}"
  shift || true
  [[ -n "$name" && $# -gt 0 ]] || { echo "Usage: zcrew send [--compact] <name> <message>" >&2; exit 1; }
  local message="$*"
  mx_require_session
  logger "send" "info" "entry name=$name msgLen=${#message}"

  claim_main_for_send >/dev/null
  local sender_name
  sender_name="$(resolve_sender_name_readonly)"
  local target_agent
  target_agent="$(lookup_registered_agent "$name")"

  local pane_id
  pane_id=$(lookup_registered_pane_id "$name")
  if [[ -z "$pane_id" ]]; then
    logger "send" "error" "unknown name=$name"
    if [[ -n "${BX_INSIDE:-}" && "$name" == "main" ]]; then
      echo 'zcrew: no main registered. Ask the user to run "zcrew claim" in the orchestrator pane.' >&2
    else
      echo "zcrew: unknown pane name '$name'" >&2
    fi
    exit 1
  fi

  local target_project_dir
  target_project_dir="$(lookup_registered_project_dir "$name")"
  if [[ -z "$target_project_dir" ]]; then
    local target_cwd
    target_cwd="$(lookup_registered_cwd "$name")"
    if target_project_dir="$(resolve_project_dir_from_path_if_resolvable "$target_cwd")"; then
      backfill_registered_project_dir "$name" "$target_project_dir"
    else
      echo "zcrew: project ownership for pane '$name' is unknown; respawn pane." >&2
      exit 1
    fi
  fi
  if [[ "$target_project_dir" != "$PROJECT_DIR" ]]; then
    {
      echo "zcrew: refusing to send to pane '$name' registered in a different project."
      echo "zcrew: current project: $PROJECT_DIR"
      echo "zcrew: target project: $target_project_dir"
    } >&2
    exit 1
  fi

  if [[ -n "$sender_name" && "$sender_name" == "$name" ]]; then
    echo "zcrew: cannot send to self" >&2
    exit 1
  fi

  if [[ -n "${BX_INSIDE:-}" && "$name" != "main" ]]; then
    echo "zcrew: worker panes cannot send directly to other workers. Send results, questions, or blockers to main with: $REPLY_CMD." >&2
    exit 1
  fi

  local reg_status
  reg_status="$(lookup_registered_status "$name")"
  if [[ "$reg_status" == "detached" ]]; then
    logger "send" "warn" "detached pane name=$name paneId=$pane_id"
    echo "zcrew: name='$name' is detached (pane gone after restart); respawn or unregister." >&2
    echo "  zcrew spawn $target_agent $name     # respawn" >&2
    echo "  zcrew unregister $name               # remove entry" >&2
    exit 1
  fi

  if ! live_pane_ids | grep -qFx "$pane_id"; then
    logger "send" "warn" "stale pane name=$name paneId=$pane_id"
    if [[ -n "${BX_INSIDE:-}" && "$name" == "main" ]]; then
      echo 'zcrew: no live main registered. Ask the user to run "zcrew claim" in the orchestrator pane.' >&2
      exit 1
    fi
    print_stale_send_error "$name" "$pane_id" "$target_agent"
    exit 1
  fi

  refresh_claude_auth_for_target "$(lookup_registered_cwd "$name")" "$target_agent"
  local tell_bin
  tell_bin="$(resolve_lib_dir)/tell"
  if [[ ! -x "$tell_bin" ]]; then
    echo "zcrew: missing tell transport at $tell_bin — run: zcrew install ." >&2
    exit 1
  fi

  if [[ "$do_compact" == "true" ]]; then
    "$tell_bin" "$pane_id" "/compact"
    logger "send" "info" "sent /compact to $name, waiting 10s"
    sleep 10
  fi

  local send_body
  local _tail_only=$'\n\n'"Only reply when you have a result, finding, blocker, or question. Never send acknowledgments. Never send to other workers."
  if [[ -z "${BX_INSIDE:-}" && ! "$message" =~ ^/[a-zA-Z][a-zA-Z0-9_-]*($|[[:space:]]) ]]; then
    if [[ "$target_agent" == "claude" || "$target_agent" == "codex" || "$target_agent" == "pi" ]]; then
      # Each managed worker auto-fires replies on its own:
      #   claude → SessionStop hook
      #   codex  → app-server adapter on turn/completed
      #   pi     → native extension's agent_end handler
      # Worker just writes its result; no instructions needed.
      send_body="$message"
    else
      send_body="${message}"$'\n\n'"Call the mcp__zcrew__zcrew_reply tool with your message. If unavailable, run \`${REPLY_CMD}\` in your shell.${_tail_only}"
    fi
  elif [[ -n "${BX_INSIDE:-}" && "$name" == "main" && ! "$message" =~ ^/[a-zA-Z][a-zA-Z0-9_-]*($|[[:space:]]) ]]; then
    send_body=$'\n\n'"Reply from ${sender_name:-unknown}:"$'\n'"${message}"
  else
    send_body="$message"
  fi

  "$tell_bin" "$pane_id" "$send_body"
  logger "send" "info" "sent name=$name paneId=$pane_id sender=${sender_name:-unknown} inside=${BX_INSIDE:-0}"
  echo "sent: $name ($pane_id)"
}

cmd_reply() {
  CURRENT_SUBCMD="reply"
  if [[ -z "${BX_INSIDE:-}" ]]; then
    echo "zcrew reply is for worker panes; from main, use: zcrew send <worker> \"<message>\"" >&2
    exit 1
  fi
  [[ $# -gt 0 ]] || { echo "Usage: zcrew reply <message>" >&2; exit 1; }
  cmd_send main "$@"
}

cmd_log_error() {
  local agent="${1:-unknown}"
  shift || true
  local message="${*:-}"
  [[ -n "$message" ]] || return 0

  local pane_name="${ZCREW_PANE_NAME:-${ZELLIJ_PANE_NAME:-${TMUX_PANE:-unknown}}}"
  local project_dir
  if ! project_dir="$(resolve_project_dir 2>/dev/null)"; then
    project_dir="${ZCREW_PROJECT_DIR:-}"
  fi
  [[ -n "$project_dir" && -d "$project_dir/.zcrew" ]] || {
    printf 'zcrew log-error: no project dir resolved, dropping: [%s] %s\n' "$agent" "$message" >&2
    return 1
  }

  local state_dir="$project_dir/.zcrew/state"
  local log_file="$state_dir/errors.log"
  local ts
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || printf '%s\n' 'unknown')"

  # Best-effort mkdir; fail silently if unwritable
  [[ -d "$state_dir" ]] || mkdir -p "$state_dir" 2>/dev/null || {
    printf 'zcrew log-error: cannot create state dir, dropping: [%s] %s\n' "$agent" "$message" >&2
    return 1
  }

  # Sanitize: collapse newlines/tabs in message to spaces, strip control chars
  local sanitized
  sanitized="$(printf '%s' "$message" | tr '\n\t' '  ' | tr -d '[:cntrl:]')"

  # flock-protected atomic append; fail silently if flock or write fails
  {
    flock -x 9 2>/dev/null || { printf 'zcrew log-error: cannot acquire lock, dropping: [%s] %s\n' "$agent" "$sanitized" >&2; return 1; }
    printf '%s\t%s\t%s\t%s\n' "$ts" "$agent" "$pane_name" "$sanitized" >>"$log_file" 2>/dev/null || {
      printf 'zcrew log-error: cannot write log, dropping: [%s] %s\n' "$agent" "$sanitized" >&2
      return 1
    }
  } 9>>"$log_file"
}

cmd_claim() {
  CURRENT_SUBCMD="claim"

  if [[ -n "${BX_INSIDE:-}" ]]; then
    echo "zcrew claim is host-only; run it in the orchestrator pane." >&2
    exit 1
  fi
  local pane_id=""
  if ! pane_id="$(mx_pane_id 2>/dev/null)"; then
    echo "zcrew: claim must be run inside a multiplexer pane" >&2
    exit 1
  fi
  local session=""
  if ! session="$(mx_session_name 2>/dev/null)"; then
    echo "zcrew: claim must be run inside a multiplexer pane" >&2
    exit 1
  fi

  require_project
  ensure_registry_files
  mx_require_session

  local replace=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --replace) replace=true ;;
      *) echo "Usage: zcrew claim [--replace]" >&2; exit 1 ;;
    esac
    shift
  done

  local live_main_info live_main_name live_main_pane
  live_main_info="$(lookup_live_main_info)"
  if [[ -n "$live_main_info" ]]; then
    IFS=$'\t' read -r live_main_name live_main_pane <<< "$live_main_info"
    if [[ "$live_main_pane" == "$pane_id" ]]; then
      return 0
    fi
    if [[ "$replace" != "true" ]]; then
      echo "zcrew: main is already $live_main_name (paneId $live_main_pane). Use --replace to swap." >&2
      exit 1
    fi
    echo "replacing main: $live_main_name (paneId $live_main_pane)"
    claim_main_alias true
    return 0
  fi

  claim_main_alias false
}

cmd_list() {
  CURRENT_SUBCMD="list"
  require_project
  logger "list" "info" "entry mode=${1:-plain}"
  if [[ "${1:-}" == "--json" ]]; then
    jq -c '.' "$REGISTRY_FILE"
  else
    jq '.' "$REGISTRY_FILE"
  fi
}

reconcile_registry_with_live_panes() {
  local prune="${1:-false}"
  [[ -n "${BX_INSIDE:-}" ]] && return 0

  local live_panes_json live_ids_json now registry_count
  live_panes_json=$(mx_list_panes | jq -Rsc 'split("\n") | map(select(length>0) | split("\t") | {id: .[0], title: .[1]})')
  live_ids_json=$(printf '%s' "$live_panes_json" | jq '[.[].id]')
  registry_count=$(jq '(.panes // {}) | length' "$REGISTRY_FILE")
  if [[ "$prune" == "true" && "$live_ids_json" == "[]" && "$registry_count" -gt 0 ]]; then
    echo "warning: multiplexer returned no live panes; preserving non-empty registry" >&2
    return 0
  fi
  now=$(date +%s)

  # Three things at once:
  # 1) Rebind registered entries by pane title (survives mux restart),
  #    or mark alive if paneId still live, or detached if gone.
  # 2) Prune only detached entries when --prune.
  # 3) Auto-register live panes that aren't in the registry as pane-<id>.
  registry_write_jq '
    .version = 1
    | .panes = (.panes // {})
    # Build liveByTitle (first match wins on title collision)
    | ($livePanes | reduce .[] as $p ({}; if has($p.title) then . else .[$p.title] = $p.id end)) as $liveByTitle
    | ($livePanes | map(.id)) as $liveIds
    # Step 1: rebind by title, mark alive by paneId, or detached
    | .panes |= with_entries(
        if $liveByTitle[(.key)] != null then
          .value.paneId = $liveByTitle[(.key)]
          | .value.status = "alive"
          | .value.lastSeen = ($now | tonumber)
        elif ((.value.paneId // "") as $id | $liveIds | index($id)) != null then
          .value.status = "alive"
          | .value.lastSeen = ($now | tonumber)
        else
          .value.status = "detached"
        end
      )
    # Step 2: prune only detached entries if --prune
    | if $prune == "true" then
        .panes |= with_entries(select(.value.status != "detached"))
      else
        .
      end
    # Step 3: auto-register unknown live panes as pane-<id>
    | . as $root
    | .panes += (
        $livePanes
        | map(select(
            ((.id as $id | ($root.panes | to_entries | map(.value.paneId == $id) | any)) | not)
            and ((.title as $t | ($root.panes | keys | index($t)) | not))
          ))
        | map({
            ("pane-" + .id): {
              paneId: .id,
              sessionId: null,
              agent: "unknown",
              projectDir: $projectDir,
              cwd: null,
              pid: null,
              lastSeen: ($now | tonumber),
              status: "alive"
            }
          })
        | add // {}
      )
  ' \
    --argjson livePanes "$live_panes_json" \
    --arg prune "$prune" \
    --arg projectDir "$PROJECT_DIR" \
    --arg now "$now"

  walk_codex_worker_orphans "safe"
}

cmd_gc() {
  CURRENT_SUBCMD="gc"
  require_project
  [[ -n "${BX_INSIDE:-}" ]] && return 0
  local force="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force="true" ;;
      *) echo "Usage: zcrew gc [--force]" >&2; exit 1 ;;
    esac
    shift
  done
  if [[ "$force" == "true" ]]; then
    walk_codex_worker_orphans "force"
  else
    walk_codex_worker_orphans "safe"
  fi
  echo "gc complete"
}

cmd_sync() {
  CURRENT_SUBCMD="sync"
  ZCREW_AUTO_SYNC=0
  require_project
  local prune="true"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keep-stale) prune="false" ;;
      --prune) prune="true" ;;
      *) echo "Usage: zcrew sync [--keep-stale|--prune]" >&2; exit 1 ;;
    esac
    shift
  done
  logger "sync" "info" "entry prune=$prune"

  reconcile_registry_with_live_panes "$prune"

  logger "sync" "info" "done prune=$prune"
  echo "synced"
}

dispatch_registry_command() {
  local fn="$1"
  shift

  ZCREW_PROJECT_READY=0

  "$fn" "$@"
}

main() {
  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    init) cmd_init "$@" ;;
    install) cmd_install "$@" ;;
    register) dispatch_registry_command cmd_register "$@" ;;
    unregister) dispatch_registry_command cmd_unregister "$@" ;;
    rename) dispatch_registry_command cmd_rename "$@" ;;
    close) dispatch_registry_command cmd_close "$@" ;;
    spawn) dispatch_registry_command cmd_spawn "$@" ;;
    send) dispatch_registry_command cmd_send "$@" ;;
    reply) dispatch_registry_command cmd_reply "$@" ;;
    claim) dispatch_registry_command cmd_claim "$@" ;;
    list) dispatch_registry_command cmd_list "$@" ;;
    sync) cmd_sync "$@" ;;
    gc) cmd_gc "$@" ;;
    log-error) cmd_log_error "$@" ;;
    *)
      cat <<USAGE
Usage: zcrew <command>

Commands:
  init
  install <target-project-dir>
  spawn [--model <model>] <agent> <name>
  rename <old> <new>
  close <name>
  send <name> <message>
  reply <message>
  claim [--replace]
  list [--json]
  sync [--keep-stale|--prune]   # --prune removes detached entries only
  gc [--force]
  log-error <agent> <message>
  register <name> [--paneId X] [--sessionId Y] [--agent A] [--cwd P] [--pid N] [--status S]
USAGE
      exit 1
      ;;
  esac
}

main "$@"
